#!/bin/bash

set -e

# cco - Claude Container (or Claude Condom if you're so inclined)
# A thin protective layer for Claude Code
# Supports multiple sandboxing backends: native (bubblewrap/seatbelt) or Docker

# Sandbox backend preference
SANDBOX_BACKEND="" # auto, native, docker

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Single mechanism for all user-facing messages: colored icon + text to stderr
msg() {
	local color="$1" icon="$2" text="$3"
	echo -e "${color}${icon}${NC} ${text}" >&2
}

log() { msg "$GREEN" "▶" "$1"; }
warn() { msg "$YELLOW" "⚠" "$1"; }
error() { msg "$RED" "✗" "$1"; }

# Determine if we're running from installation or development
if [[ -f "./Dockerfile" && -f "./cco" ]]; then
	# Current directory is a cco development environment
	CCO_INSTALLATION_DIR="$PWD"
	log "Detected cco development environment, building locally"
elif [[ -d "$HOME/.local/share/cco/.git" && "$(basename "$(dirname "$0")")" != "cco" ]]; then
	# Running from symlink, use installation directory
	CCO_INSTALLATION_DIR="$HOME/.local/share/cco"
else
	# Running from development directory
	CCO_INSTALLATION_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
fi

DEFAULT_IMAGE_NAME="cco:latest"
IMAGE_NAME="$DEFAULT_IMAGE_NAME"
# Sanitize directory name for Docker container naming (only alphanumeric, underscore, dash, dot)
sanitized_dir=$(basename "$PWD" | tr -c '[:alnum:]._-' '_')
CONTAINER_NAME=""
persist_scope_root=""
persist_scope_slug=""

hash_string() {
	local input="$1"
	if command -v sha256sum &>/dev/null; then
		printf '%s' "$input" | sha256sum | awk '{print substr($1, 1, 12)}'
	elif command -v shasum &>/dev/null; then
		printf '%s' "$input" | shasum -a 256 | awk '{print substr($1, 1, 12)}'
	else
		printf '%s' "$input" | cksum | awk '{print $1}'
	fi
}

sanitize_name_fragment() {
	local input="$1"
	printf '%s' "$input" | tr -c '[:alnum:]._-' '_' | cut -c1-40
}

is_valid_persist_name() {
	local input="$1"
	[[ "$input" =~ ^[[:alnum:]._-]+$ ]]
}

is_known_subcommand() {
	case "$1" in
	shell | codex | droid | opencode | pi | gemini | self-update | cleanup | info | backup-creds | restore-creds | pull | rebuild)
		return 0
		;;
	*)
		return 1
		;;
	esac
}

using_custom_docker_image() {
	[[ -n "$docker_image_override" ]]
}

generate_container_name() {
	if [[ -n "$persist_container_target" ]]; then
		printf '%s\n' "$persist_container_target"
		return
	fi

	local scope_root="${persist_scope_root:-$PWD}"
	local scope_slug="${persist_scope_slug:-$sanitized_dir}"
	local scope_root_hash
	scope_root_hash=$(hash_string "$scope_root")
	if [[ "$persist_mode" == true ]]; then
		if [[ -n "$persist_name_flag" ]]; then
			local persist_name_slug
			persist_name_slug=$(sanitize_name_fragment "$persist_name_flag")
			printf 'cco-%s-persist-%s-%s-%s\n' \
				"$scope_slug" \
				"$persist_name_slug" \
				"$(hash_string "$persist_name_flag")" \
				"$scope_root_hash"
		else
			printf 'cco-%s-persist-%s\n' "$scope_slug" "$scope_root_hash"
		fi
	else
		printf 'cco-%s-%s-%s\n' "$sanitized_dir" "$(date +%s)" "$$"
	fi
}

persist_state_root() {
	printf '%s/.local/share/cco/persist\n' "$HOME"
}

persist_state_dir() {
	printf '%s/%s\n' "$(persist_state_root)" "$CONTAINER_NAME"
}

resolve_persist_scope_root() {
	local git_common_dir_raw git_common_dir
	if command -v git &>/dev/null; then
		git_common_dir_raw="$(git rev-parse --git-common-dir 2>/dev/null)" || true
		if [[ -n "$git_common_dir_raw" ]] && git_common_dir="$(resolve_existing_dir "$git_common_dir_raw")"; then
			if [[ "$(basename "$git_common_dir")" == ".git" ]]; then
				printf '%s\n' "$(dirname "$git_common_dir")"
			else
				printf '%s\n' "$git_common_dir"
			fi
			return
		fi
	fi

	printf '%s\n' "$PWD"
}

persist_scope_slug_for_root() {
	local scope_root="$1"
	local base_name
	base_name=$(basename "$scope_root")
	if [[ -n "$base_name" && "$base_name" != "/" && "$base_name" != "." ]]; then
		sanitize_name_fragment "$base_name"
	else
		printf 'workspace\n'
	fi
}

probe_linux_bwrap() {
	bwrap --ro-bind / / true
}

explain_linux_bwrap_failure() {
	local probe_output="$1"
	warn "Native Linux sandbox is unavailable: bubblewrap is installed but cannot start."
	if [[ "$probe_output" == *"setting up uid map"* && "$probe_output" == *"Permission denied"* ]]; then
		warn "bubblewrap could not set up its uid_map; AppArmor/user-namespace policy is preventing setup."
	elif [[ -n "$probe_output" ]]; then
		local first_line="${probe_output%%$'\n'*}"
		warn "bubblewrap probe failed: $first_line"
	fi
}

# Detect available sandbox backends
detect_sandbox_backend() {
	local force_backend="$1"
	local forced_native=false

	if [[ -n "$force_backend" ]]; then
		case "$force_backend" in
		docker)
			SANDBOX_BACKEND="docker"
			return
			;;
		native)
			forced_native=true
			;;
		auto | "")
			# Continue with auto-detection
			;;
		*)
			error "Invalid sandbox backend: $force_backend"
			error "Valid options: auto, native, docker"
			exit 1
			;;
		esac
	fi

	# Auto-detect best available backend
	local os
	os="$(uname -s)"

	if [[ "$os" == "Darwin" ]]; then
		# macOS: Check for sandbox-exec (Seatbelt)
		if command -v sandbox-exec &>/dev/null; then
			SANDBOX_BACKEND="native"
			log "Using native sandbox (Seatbelt)"
		elif [[ "$forced_native" == true ]]; then
			error "Native sandbox was requested with --backend native, but sandbox-exec is not available."
			exit 1
		elif command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
			SANDBOX_BACKEND="docker"
			log "Using Docker sandbox (Seatbelt not available)"
		else
			error "No sandbox backend available. Install Docker or ensure sandbox-exec is available."
			exit 1
		fi
	elif [[ "$os" == "Linux" ]]; then
		# Linux: Check for bubblewrap
		if command -v bwrap &>/dev/null; then
			local bwrap_probe_output
			if bwrap_probe_output=$(probe_linux_bwrap 2>&1); then
				SANDBOX_BACKEND="native"
				log "Using native sandbox (bubblewrap)"
			else
				explain_linux_bwrap_failure "$bwrap_probe_output"
				if [[ "$forced_native" == true ]]; then
					error "Native sandbox was requested with --backend native, so cco cannot fall back automatically."
					exit 1
				elif command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
					SANDBOX_BACKEND="docker"
					log "Using Docker sandbox (bubblewrap blocked by host policy)"
				else
					error "No sandbox backend available. Install Docker or fix the host bubblewrap/AppArmor policy."
					exit 1
				fi
			fi
		elif command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
			if [[ "$forced_native" == true ]]; then
				error "Native sandbox was requested with --backend native, but bubblewrap is not installed."
				exit 1
			fi
			SANDBOX_BACKEND="docker"
			log "Using Docker sandbox (bubblewrap not available)"
		else
			if [[ "$forced_native" == true ]]; then
				error "Native sandbox was requested with --backend native, but bubblewrap is not installed."
				exit 1
			fi
			error "No sandbox backend available. Install bubblewrap or Docker."
			exit 1
		fi
	else
		error "Unsupported OS: $os"
		exit 1
	fi
}

# Determine Claude command to use (configurable via CLI flag or environment variable)
get_claude_command() {
	if [[ -n "$claude_command_flag" ]]; then
		echo "$claude_command_flag"
	elif [[ -n "$CCO_CLAUDE_COMMAND" ]]; then
		echo "$CCO_CLAUDE_COMMAND"
	else
		echo "claude"
	fi
}

# Determine command to run (configurable via CLI flag or environment variable)
# This allows running arbitrary commands instead of Claude
get_command() {
	if [[ -n "$command_flag" ]]; then
		echo "$command_flag"
	elif [[ -n "$CCO_COMMAND" ]]; then
		echo "$CCO_COMMAND"
	else
		get_claude_command
	fi
}

# Load agent-specific behavior/policies from dedicated modules.
if [[ -f "$CCO_INSTALLATION_DIR/lib/agents.sh" ]]; then
	# shellcheck source=/dev/null
	source "$CCO_INSTALLATION_DIR/lib/agents.sh"
else
	error "Missing required module: $CCO_INSTALLATION_DIR/lib/agents.sh"
	exit 1
fi

path_in_array() {
	local needle="$1"
	shift
	for element in "$@"; do
		if [[ "$element" == "$needle" ]]; then
			return 0
		fi
	done
	return 1
}

remove_path_from_array() {
	local target="$1"
	shift
	local new_arr=()

	for element in "$@"; do
		if [[ "$element" != "$target" ]]; then
			new_arr+=("$element")
		fi
	done

	# Use newline delimiter (not space) so paths with spaces survive round-trip
	printf '%s\n' "${new_arr[@]}"
}

# Resolve a path to an absolute form, tolerating files or directories that may not yet exist.
resolve_path() {
	local input="$1"
	local expanded="$input"
	if [[ "$expanded" == ~* ]]; then
		expanded="${expanded/#\~/$HOME}"
	fi

	if [[ -d "$expanded" ]]; then
		(cd "$expanded" && pwd)
		return
	fi

	local dir base
	dir=$(dirname "$expanded")
	base=$(basename "$expanded")
	if [[ "$dir" == ~* ]]; then
		dir="${dir/#\~/$HOME}"
	fi
	if [[ -d "$dir" ]]; then
		(cd "$dir" && printf '%s/%s\n' "$(pwd)" "$base")
	else
		# Fall back to combining with current working directory.
		if [[ "$dir" == "." ]]; then
			printf '%s/%s\n' "$PWD" "$base"
		else
			printf '%s/%s\n' "$dir" "$base"
		fi
	fi
}

resolve_existing_dir() {
	local input="$1"
	local expanded="$input"
	if [[ "$expanded" == ~* ]]; then
		expanded="${expanded/#\~/$HOME}"
	fi
	if [[ ! -d "$expanded" ]]; then
		return 1
	fi
	(cd "$expanded" && pwd -P)
}

add_rw_path() {
	local path="$1"
	if [[ ! -d "$path" ]]; then
		warn "Directory does not exist: $path"
		return 1
	fi
	IFS=$'\n' read -r -d '' -a additional_ro_paths < <(remove_path_from_array "$path" "${additional_ro_paths[@]}") || true
	IFS=$'\n' read -r -d '' -a deny_paths < <(remove_path_from_array "$path" "${deny_paths[@]}") || true
	if ! path_in_array "$path" "${additional_dirs[@]}"; then
		additional_dirs+=("$path")
	fi
	return 0
}

add_ro_path() {
	local path="$1"
	if [[ ! -e "$path" ]]; then
		warn "Path does not exist for read-only share: $path"
		return 1
	fi
	IFS=$'\n' read -r -d '' -a additional_dirs < <(remove_path_from_array "$path" "${additional_dirs[@]}") || true
	IFS=$'\n' read -r -d '' -a deny_paths < <(remove_path_from_array "$path" "${deny_paths[@]}") || true
	if ! path_in_array "$path" "${additional_ro_paths[@]}"; then
		additional_ro_paths+=("$path")
	fi
	return 0
}

add_deny_path() {
	local path="$1"
	if [[ ! -e "$path" ]]; then
		warn "Path does not exist for deny rule: $path"
		return 1
	fi
	IFS=$'\n' read -r -d '' -a additional_dirs < <(remove_path_from_array "$path" "${additional_dirs[@]}") || true
	IFS=$'\n' read -r -d '' -a additional_ro_paths < <(remove_path_from_array "$path" "${additional_ro_paths[@]}") || true
	if ! path_in_array "$path" "${deny_paths[@]}"; then
		deny_paths+=("$path")
	fi
}

handle_add_dir_entry() {
	local raw="$1"
	local mode="rw"
	if [[ "$raw" == *":ro" ]]; then
		raw="${raw%:ro}"
		mode="ro"
	elif [[ "$raw" == *":rw" ]]; then
		raw="${raw%:rw}"
	fi

	local resolved
	resolved=$(resolve_path "$raw")

	if [[ -z "$resolved" ]]; then
		return
	fi

	case "$mode" in
	rw)
		add_rw_path "$resolved"
		;;
	ro)
		add_ro_path "$resolved"
		;;
	*)
		error "Unknown mode for --add-dir entry: $mode"
		exit 1
		;;
	esac
}

# Parse additionalDirectories from .claude/settings.local.json
# Prefer python3 for portability and fall back to jq when available.
load_additional_directories_from_settings() {
	local settings_file="$PWD/.claude/settings.local.json"
	if [[ ! -f "$settings_file" ]]; then
		return
	fi

	local parser=""
	if command -v python3 &>/dev/null; then
		parser="python3"
	elif command -v jq &>/dev/null; then
		parser="jq"
	else
		warn "python3/jq not found; skipping additionalDirectories from $settings_file"
		return
	fi

	local dirs parse_output parse_error parse_status
	if [[ "$parser" == "python3" ]]; then
		if parse_output=$(
			python3 - "$settings_file" 2>&1 <<'PY'
import json
import sys

try:
    with open(sys.argv[1], encoding="utf-8") as handle:
        data = json.load(handle)
except Exception as exc:
    print(f"Unable to parse settings.local.json: {exc}", file=sys.stderr)
    sys.exit(1)

directories = data.get("additionalDirectories", [])
if directories is None:
    sys.exit(0)
if not isinstance(directories, list):
    print("Unable to parse settings.local.json: additionalDirectories must be an array", file=sys.stderr)
    sys.exit(1)

for entry in directories:
    if isinstance(entry, str):
        print(entry)
PY
		); then
			parse_status=0
		else
			parse_status=$?
		fi
	else
		if parse_output=$(jq -r '
			(.additionalDirectories // []) as $dirs
			| if ($dirs | type) != "array" then
				error("Unable to parse settings.local.json: additionalDirectories must be an array")
			  else
				$dirs[]
			  end
			| select(type == "string")
		' "$settings_file" 2>&1); then
			parse_status=0
		else
			parse_status=$?
		fi
	fi

	if [[ $parse_status -ne 0 ]]; then
		parse_error=$(printf '%s' "$parse_output" | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')
		if [[ -z "$parse_error" ]]; then
			parse_error="Unable to parse settings.local.json"
		fi
		warn "Skipping additionalDirectories from $settings_file: $parse_error"
		return
	fi

	dirs="$parse_output"

	local dir
	while IFS= read -r dir; do
		[[ -z "$dir" ]] && continue
		local resolved
		resolved=$(resolve_path "$dir")
		if [[ -n "$resolved" && -d "$resolved" ]]; then
			if ! path_in_array "$resolved" "${additional_dirs[@]}"; then
				add_rw_path "$resolved"
				log "Adding additional directory from settings: $resolved"
			fi
		else
			warn "Skipping additionalDirectories entry (not a directory): $dir"
		fi
	done <<<"$dirs"
}

# Check if Docker is available (only when using Docker backend)
check_docker_dependencies() {
	# Check for Docker
	if ! command -v docker &>/dev/null; then
		error "Docker is not installed or not in PATH"
		error "Please install Docker: https://docs.docker.com/get-docker/"
		exit 1
	fi

	if ! docker info &>/dev/null; then
		error "Docker daemon is not running"
		error "Please start Docker and try again"
		exit 1
	fi
}

# Check general dependencies
check_dependencies() {
	# Check for git (required for version detection and updates)
	if ! command -v git &>/dev/null; then
		error "Git is not installed or not in PATH"
		error "Please install git: https://git-scm.com/downloads"
		exit 1
	fi
}

# Determine Claude Code config directory following Claude Code's current
# default behavior, with a legacy ~/.config/claude fallback for older setups.
get_claude_config_dir() {
	if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
		echo "$CLAUDE_CONFIG_DIR"
	else
		echo "$HOME/.claude"
	fi
}

# Find where Claude Code actually stores its configuration
find_claude_config_dir() {
	local primary_dir
	primary_dir=$(get_claude_config_dir)
	local legacy_dir="$HOME/.config/claude"

	# Check Claude Code's current default location first.
	if [[ -d "$primary_dir" || -f "$primary_dir/.credentials.json" ]]; then
		echo "$primary_dir"
		return
	fi

	# Fall back to older XDG-style layouts when present.
	if [[ -d "$legacy_dir" || -f "$legacy_dir/.credentials.json" ]]; then
		echo "$legacy_dir"
		return
	fi

	# Return primary location for error reporting
	echo "$primary_dir"
}

get_claude_keychain_account() {
	if [[ -n "${USER:-}" ]]; then
		printf '%s\n' "$USER"
		return
	fi

	if id -un >/dev/null 2>&1; then
		id -un
		return
	fi

	printf 'claude-code-user\n'
}

get_claude_keychain_oauth_suffix() {
	if [[ -n "${CLAUDE_CODE_CUSTOM_OAUTH_URL:-}" ]]; then
		printf '%s\n' "-custom-oauth"
		return
	fi

	printf '\n'
}

sha256_prefix8() {
	local input="$1"

	if command -v shasum >/dev/null 2>&1; then
		printf '%s' "$input" | shasum -a 256 | awk '{print substr($1, 1, 8)}'
		return
	fi

	if command -v sha256sum >/dev/null 2>&1; then
		printf '%s' "$input" | sha256sum | awk '{print substr($1, 1, 8)}'
		return
	fi

	if command -v openssl >/dev/null 2>&1; then
		printf '%s' "$input" | openssl dgst -sha256 | awk '{print substr($NF, 1, 8)}'
		return
	fi

	return 1
}

get_claude_keychain_service_name() {
	local oauth_suffix service_name
	oauth_suffix=$(get_claude_keychain_oauth_suffix)
	service_name="Claude Code${oauth_suffix}-credentials"

	if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
		local config_hash
		config_hash=$(sha256_prefix8 "$(get_claude_config_dir)") || return 1
		service_name="${service_name}-${config_hash}"
	fi

	printf '%s\n' "$service_name"
}

# Check if Claude authentication is needed based on the command being run
needs_claude_authentication() {
	# If we're running a custom command (not Claude), skip Claude authentication
	if [[ -n "$command_flag" || -n "$CCO_COMMAND" ]]; then
		return 1 # Don't need Claude auth
	fi

	# If we're in shell mode, we don't need Claude authentication
	if [[ "$shell_mode" = true ]]; then
		return 1 # Don't need Claude auth
	fi

	# Otherwise we need Claude authentication
	return 0 # Need Claude auth
}

# Read the host's current Claude credential payload so startup checks can
# reason about expiry without teaching cco to perform OAuth itself.
capture_macos_keychain_credentials() {
	local payload_file error_file keychain_service keychain_account
	keychain_credentials_payload=""
	keychain_credentials_error=""
	keychain_service=$(get_claude_keychain_service_name) || return 1
	keychain_account=$(get_claude_keychain_account)

	payload_file=$(mktemp)
	error_file=$(mktemp)

	if security find-generic-password -s "$keychain_service" -a "$keychain_account" -w >"$payload_file" 2>"$error_file"; then
		keychain_credentials_payload=$(cat "$payload_file")
		rm -f "$payload_file" "$error_file"
		return 0
	fi

	keychain_credentials_error=$(tr '\n' ' ' <"$error_file" | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')
	rm -f "$payload_file" "$error_file"
	return 1
}

get_claude_credentials_file_path() {
	local claude_config_dir
	claude_config_dir=$(find_claude_config_dir)
	printf '%s/.credentials.json\n' "$claude_config_dir"
}

get_claude_credentials_payload() {
	local credentials_file
	credentials_file=$(get_claude_credentials_file_path)

	if command -v security &>/dev/null; then
		if capture_macos_keychain_credentials; then
			printf '%s' "$keychain_credentials_payload"
			return 0
		fi
	fi

	if [[ -f "$credentials_file" ]]; then
		cat "$credentials_file"
	fi
}

extract_oauth_expiry_ms() {
	local credentials_payload="$1"
	local expires_at="" parse_status=0

	# Prefer the Claude OAuth expiry field, but tolerate the older flat payload shape.
	if command -v python3 &>/dev/null; then
		if expires_at=$(
			python3 - "$credentials_payload" 2>/dev/null <<'PY'
import json
import sys

try:
    data = json.loads(sys.argv[1])
except Exception:
    sys.exit(1)

candidates = []
claude_oauth = data.get("claudeAiOauth")
if isinstance(claude_oauth, dict):
    candidates.append(claude_oauth.get("expiresAt"))
candidates.append(data.get("expiresAt"))

for value in candidates:
    if isinstance(value, bool):
        continue
    if isinstance(value, int):
        print(value)
        sys.exit(0)
    if isinstance(value, float) and value.is_integer():
        print(int(value))
        sys.exit(0)
    if isinstance(value, str) and value.isdigit():
        print(value)
        sys.exit(0)

sys.exit(1)
PY
		); then
			parse_status=0
		else
			parse_status=$?
		fi
	elif command -v jq &>/dev/null; then
		if expires_at=$(printf '%s' "$credentials_payload" | jq -r '
			[
				.claudeAiOauth.expiresAt?,
				.expiresAt?
			]
			| map(
				if type == "number" then tostring
				elif type == "string" and test("^[0-9]+$") then .
				else null
				end
			)
			| map(select(. != null))
			| .[0] // empty
		' 2>/dev/null); then
			parse_status=0
		else
			parse_status=$?
		fi
	else
		return 1
	fi

	if [[ $parse_status -ne 0 || -z "$expires_at" || ! "$expires_at" =~ ^[0-9]+$ ]]; then
		return 1
	fi

	# Claude currently stores millisecond epochs, but tolerate second epochs.
	if ((expires_at < 1000000000000)); then
		expires_at=$((expires_at * 1000))
	fi

	printf '%s\n' "$expires_at"
}

oauth_token_needs_startup_refresh() {
	local expires_at_ms="$1"
	local now_ms refresh_window_ms
	now_ms=$(($(date +%s) * 1000))
	refresh_window_ms=$((10 * 60 * 1000))

	((expires_at_ms <= now_ms + refresh_window_ms))
}

oauth_token_is_expired() {
	local expires_at_ms="$1"
	local now_ms
	now_ms=$(($(date +%s) * 1000))

	((expires_at_ms <= now_ms))
}

oauth_token_needs_background_refresh() {
	local expires_at_ms="$1"
	local now_ms refresh_window_ms
	now_ms=$(($(date +%s) * 1000))
	refresh_window_ms=$((2 * 60 * 60 * 1000))

	((expires_at_ms <= now_ms + refresh_window_ms))
}

oauth_background_refresh_lock_dir() {
	local marker_key marker_hash
	marker_key="$(get_claude_config_dir):$SANDBOX_BACKEND"
	marker_hash=$(sha256_prefix8 "$marker_key") || return 1
	printf '%s/cco/oauth-refresh-%s.lock\n' "${XDG_CACHE_HOME:-$HOME/.cache}" "$marker_hash"
}

backend_can_persist_oauth_refresh() {
	if command -v security &>/dev/null; then
		if [[ "$SANDBOX_BACKEND" == "native" ]]; then
			[[ "$allow_keychain" == true ]]
			return
		fi

		if [[ "$SANDBOX_BACKEND" == "docker" ]]; then
			[[ "$allow_oauth_refresh" == true ]]
			return
		fi

		return 1
	fi

	if [[ "$SANDBOX_BACKEND" == "native" ]]; then
		return 1
	fi

	if [[ "$SANDBOX_BACKEND" == "docker" && "$allow_oauth_refresh" == true ]]; then
		return 0
	fi

	return 1
}

run_unsandboxed_claude_refresh() {
	local claude_cmd_str refresh_dir status
	claude_cmd_str=$(get_claude_command)

	if [[ -z "$claude_cmd_str" ]]; then
		error "Could not determine which Claude command to use for refresh"
		return 1
	fi

	local claude_cmd=()
	read -ra claude_cmd <<<"$claude_cmd_str"
	refresh_dir=$(mktemp -d)

	log "Refreshing Claude OAuth credentials before starting sandbox; this may take a moment..."
	(
		cd "$refresh_dir" || exit 1
		"${claude_cmd[@]}" -p --output-format text --no-session-persistence "Reply with OK and nothing else."
	) >/dev/null
	status=$?

	rm -rf "$refresh_dir"
	return "$status"
}

start_background_claude_refresh() {
	local lock_dir
	lock_dir=$(oauth_background_refresh_lock_dir) || return 0
	mkdir -p "$(dirname "$lock_dir")" 2>/dev/null || return 0

	if ! mkdir "$lock_dir" 2>/dev/null; then
		log "Claude OAuth credential refresh is already running in the background"
		return 0
	fi

	log "Refreshing Claude OAuth credentials in the background before they expire..."
	(
		trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT
		run_unsandboxed_claude_refresh >/dev/null 2>&1 || true
	) &
}

confirm_default_yes() {
	local prompt="$1"
	local auto_message="${2:-}"

	if [[ "$yes_flag" == true ]]; then
		if [[ -n "$auto_message" ]]; then
			log "$auto_message"
		fi
		return 0
	fi

	if [[ -t 0 && -t 1 ]]; then
		echo
		read -p "$prompt [Y/n] " -r
		if [[ $REPLY =~ ^([Nn])$ ]]; then
			return 1
		fi
		return 0
	fi

	return 1
}

is_ssh_session() {
	[[ -n "${SSH_CONNECTION:-}" || -n "${SSH_TTY:-}" ]]
}

looks_like_locked_keychain_error() {
	local message
	message=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
	case "$message" in
	*"user interaction is not allowed"* | *"interaction is not allowed"* | *"errsecinteractionnotallowed"* | *"cssmerr_csp_no_user_interaction"*)
		return 0
		;;
	esac
	return 1
}

get_login_keychain_path() {
	local login_keychain
	login_keychain=$(security login-keychain 2>/dev/null | tr -d '"' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' | head -n 1)
	if [[ -n "$login_keychain" ]]; then
		printf '%s\n' "$login_keychain"
	else
		printf '%s/Library/Keychains/login.keychain-db\n' "$HOME"
	fi
}

capture_macos_login_keychain_status() {
	local error_file login_keychain
	keychain_status_error=""
	login_keychain=$(get_login_keychain_path)
	error_file=$(mktemp)

	if security show-keychain-info "$login_keychain" >/dev/null 2>"$error_file"; then
		keychain_status_error=$(tr '\n' ' ' <"$error_file" | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')
		rm -f "$error_file"
		[[ -z "$keychain_status_error" ]]
		return 0
	fi

	keychain_status_error=$(tr '\n' ' ' <"$error_file" | sed 's/[[:space:]]\+/ /g; s/^ //; s/ $//')
	rm -f "$error_file"
	return 1
}

macos_login_keychain_appears_locked() {
	if ! is_ssh_session; then
		return 1
	fi

	if capture_macos_login_keychain_status; then
		return 1
	fi

	looks_like_locked_keychain_error "$keychain_status_error"
}

get_login_keychain_unlock_command() {
	local login_keychain
	login_keychain=$(get_login_keychain_path)
	printf 'security unlock-keychain %q\n' "$login_keychain"
}

run_macos_keychain_unlock() {
	local login_keychain
	login_keychain=$(get_login_keychain_path)
	security unlock-keychain "$login_keychain"
}

ensure_accessible_macos_keychain_credentials() {
	local unlock_command

	if capture_macos_keychain_credentials; then
		log "Verified Claude Code credentials in macOS Keychain"
		return 0
	fi

	if ! is_ssh_session; then
		return 1
	fi

	if ! looks_like_locked_keychain_error "$keychain_credentials_error" && ! macos_login_keychain_appears_locked; then
		return 1
	fi

	unlock_command=$(get_login_keychain_unlock_command)

	warn "cco could not read Claude Code credentials from the macOS login keychain"
	warn "Because this session is running over SSH, the login keychain is probably locked"

	if confirm_default_yes \
		"Unlock the macOS login keychain now so cco can read Claude credentials and continue?" \
		"--yes enabled; unlocking the macOS login keychain before starting cco"; then
		if ! run_macos_keychain_unlock; then
			error "Keychain unlock did not complete successfully"
			error "Run \`$unlock_command\` and then retry cco."
			exit 1
		fi

		if capture_macos_keychain_credentials; then
			log "Unlocked the macOS login keychain and verified Claude Code credentials"
			return 0
		fi

		error "cco still could not read Claude Code credentials after unlocking the login keychain"
		error "Run plain \`$(get_claude_command)\` and login again if needed, then retry cco."
		exit 1
	fi

	error "cco needs access to the macOS login keychain before this session can start"
	error "Run \`$unlock_command\` and then retry cco."
	exit 1
}

ensure_refreshable_oauth_credentials() {
	# Token from environment is managed externally; nothing to refresh
	if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
		return 0
	fi

	local credentials_payload expires_at_ms
	credentials_payload=$(get_claude_credentials_payload)

	if [[ -z "$credentials_payload" ]]; then
		return 0
	fi

	if ! expires_at_ms=$(extract_oauth_expiry_ms "$credentials_payload"); then
		return 0
	fi

	if backend_can_persist_oauth_refresh; then
		if oauth_token_needs_startup_refresh "$expires_at_ms"; then
			warn "Claude OAuth token is expired or near expiry, but this backend can persist a refresh"
		fi
		return 0
	fi

	if oauth_token_is_expired "$expires_at_ms"; then
		if ! run_unsandboxed_claude_refresh; then
			error "Claude OAuth refresh did not complete"
			error "Run plain \`$(get_claude_command)\` to re-authenticate, then retry cco."
			exit 1
		fi

		credentials_payload=$(get_claude_credentials_payload)
		if [[ -z "$credentials_payload" ]] || ! expires_at_ms=$(extract_oauth_expiry_ms "$credentials_payload"); then
			error "Could not verify Claude OAuth credentials after the refresh attempt"
			error "Run plain \`$(get_claude_command)\` to re-authenticate, then retry cco."
			exit 1
		fi

		if oauth_token_is_expired "$expires_at_ms"; then
			error "Claude OAuth credentials are still expired after the refresh attempt"
			error "Run plain \`$(get_claude_command)\` to re-authenticate, then retry cco."
			exit 1
		fi

		log "Claude OAuth credentials refreshed"
		return 0
	fi

	if oauth_token_needs_background_refresh "$expires_at_ms"; then
		start_background_claude_refresh
	fi
}

# Verify Claude Code authentication is available
verify_claude_authentication() {
	log "Verifying Claude Code authentication..."

	# If CLAUDE_CODE_OAUTH_TOKEN is set, Claude Code will use it directly
	if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
		log "Using CLAUDE_CODE_OAUTH_TOKEN from environment"
		return 0
	fi

	local claude_config_dir credentials_file
	claude_config_dir=$(find_claude_config_dir)
	credentials_file=$(get_claude_credentials_file_path)

	# Check if config directory exists
	if [[ ! -d "$claude_config_dir" ]]; then
		error "No Claude Code configuration found at $claude_config_dir"
		error "Please run \`claude\` and login to authenticate, then try again."
		exit 1
	fi

	# Verify credentials exist (simple check, no staging)
	if command -v security &>/dev/null; then
		if capture_macos_keychain_credentials; then
			log "Verified Claude Code credentials in macOS Keychain"
		elif [[ -f "$credentials_file" ]]; then
			log "Verified Claude Code credentials file exists"
		elif is_ssh_session && { looks_like_locked_keychain_error "$keychain_credentials_error" || macos_login_keychain_appears_locked; }; then
			ensure_accessible_macos_keychain_credentials
		else
			error "No Claude Code credentials found in macOS Keychain or credential file"
			error "Please run \`claude\` and login to authenticate, then try again."
			exit 1
		fi
	elif [[ -f "$credentials_file" ]]; then
		log "Verified Claude Code credentials file exists"
	else
		error "No Claude Code credentials found!"
		error "Please run \`claude\` and login to authenticate, then try again."
		exit 1
	fi

	log "Claude Code authentication verified"
}

# Sync updated credentials back to host system
sync_credentials_back() {
	local temp_creds_dir="$1"
	local original_content="$2"
	local host_creds_file="$3"
	local startup_system_content="$4"
	local temp_creds_file="$temp_creds_dir/.credentials.json"

	# Check if credentials file exists and was potentially updated
	if [[ ! -f "$temp_creds_file" ]]; then
		return 0 # No credentials file to sync
	fi

	# Check if credentials content changed
	local current_content
	current_content=$(cat "$temp_creds_file")

	# If content unchanged, no sync needed
	if [[ "$current_content" = "$original_content" ]]; then
		return 0
	fi

	log "Detected updated credentials, syncing back to host system..."

	# Safety check: Verify system credentials haven't changed during our session
	local current_system_content=""
	if [[ -n "$host_creds_file" && -f "$host_creds_file" ]]; then
		# File-backed credentials take priority even on macOS.
		current_system_content=$(cat "$host_creds_file")
	elif command -v security &>/dev/null; then
		# macOS: Check current Keychain content
		if capture_macos_keychain_credentials; then
			current_system_content="$keychain_credentials_payload"
		fi
	fi

	# Abort if system credentials changed during our session
	if [[ -n "$startup_system_content" && -n "$current_system_content" && "$startup_system_content" != "$current_system_content" ]]; then
		warn "SAFETY ABORT: System credentials were modified during session by another process"
		warn "This could be Claude CLI, another cco instance, or manual changes"
		warn "Skipping sync-back to prevent credential conflicts"
		warn "Your container's updated credentials are preserved in: $temp_creds_file"
		warn "To manually sync: ./cco restore-creds '$temp_creds_file'"
		return 1
	fi

	# Create backup timestamp
	local backup_timestamp
	backup_timestamp=$(date +"%Y%m%d_%H%M%S")

	# Sync back based on platform
	if [[ -n "$host_creds_file" && -f "$host_creds_file" ]]; then
		# File-backed credentials on any platform.
		local backup_file="${host_creds_file}.backup.$backup_timestamp"
		log "Creating backup of original credentials file..."
		if cp "$host_creds_file" "$backup_file"; then
			log "Backup saved to: $backup_file"

			# Update credentials file with new content
			if cp "$temp_creds_file" "$host_creds_file"; then
				log "Successfully updated credentials file: $host_creds_file"
			else
				warn "Failed to update credentials file: $host_creds_file"
				warn "Restoring from backup..."
				if cp "$backup_file" "$host_creds_file"; then
					warn "Successfully restored original credentials from backup"
				else
					warn "Failed to restore backup! Original credentials backup available at: $backup_file"
				fi
			fi
		else
			warn "Failed to create backup, skipping credentials update for safety"
		fi
	elif command -v security &>/dev/null; then
		# macOS: Backup and update Keychain
		log "Creating backup of original Keychain credentials..."
		local original_creds keychain_service keychain_account
		keychain_service=$(get_claude_keychain_service_name)
		keychain_account=$(get_claude_keychain_account)
		original_creds=$(security find-generic-password -s "$keychain_service" -a "$keychain_account" -w 2>/dev/null || echo "")
		if [[ -n "$original_creds" ]]; then
			# Save backup to temp location
			echo "$original_creds" >"$temp_creds_dir/.credentials.backup.$backup_timestamp.json"
			log "Backup saved to: $temp_creds_dir/.credentials.backup.$backup_timestamp.json"
		fi

		# Update Keychain with new credentials
		local creds_content
		creds_content=$(cat "$temp_creds_file")
		if security add-generic-password -U -s "$keychain_service" -a "$keychain_account" -w "$creds_content" >/dev/null 2>&1; then
			log "Successfully updated credentials in macOS Keychain"
		else
			warn "Failed to update macOS Keychain, credentials may be out of sync"
			if [[ -f "$temp_creds_dir/.credentials.backup.$backup_timestamp.json" ]]; then
				warn "Original credentials backup available at: $temp_creds_dir/.credentials.backup.$backup_timestamp.json"
				warn "To restore: security add-generic-password -U -s '$keychain_service' -a '$keychain_account' -w \"\$(cat '$temp_creds_dir/.credentials.backup.$backup_timestamp.json')\""
			fi
		fi
	fi
}

# Check if we should use pre-built image
should_use_prebuilt_image() {
	if using_custom_docker_image; then
		return 1
	fi

	# Don't use pre-built if explicitly rebuilding
	if [[ "$rebuild_image" = true ]]; then
		return 1
	fi

	# Don't use pre-built if custom packages specified
	if [[ ${#custom_packages[@]} -gt 0 ]]; then
		return 1
	fi

	# Don't use pre-built if Dockerfile has been modified locally
	if [[ -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		local dockerfile_status
		dockerfile_status=$(cd "$CCO_INSTALLATION_DIR" && git status --porcelain Dockerfile 2>/dev/null)
		if [[ -n "$dockerfile_status" ]]; then
			return 1
		fi
	fi

	return 0
}

# Get the appropriate image tag for current version
get_prebuilt_image_tag() {
	if [[ -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		local commit_sha
		commit_sha=$(cd "$CCO_INSTALLATION_DIR" && git rev-parse --short HEAD 2>/dev/null)
		echo "ghcr.io/nikvdp/cco:${commit_sha}"
	else
		echo "ghcr.io/nikvdp/cco:latest"
	fi
}

# Try to pull pre-built image
pull_prebuilt_image() {
	local image_tag
	image_tag=$(get_prebuilt_image_tag)

	log "Attempting to pull pre-built image: $image_tag"

	# First check if the image exists in the registry
	log "Checking if pre-built image is available..."
	if ! docker manifest inspect "$image_tag" >/dev/null 2>&1; then
		warn "Pre-built image not found in registry, building locally..."
		return 1
	fi

	log "Pre-built image found, downloading..."
	# Pull without timeout - let it take as long as needed
	if docker pull "$image_tag" 2>&1; then
		# Tag as local image name for consistency
		docker tag "$image_tag" "$IMAGE_NAME" >/dev/null 2>&1
		log "Successfully pulled pre-built image"
		offer_old_cco_image_cleanup "$image_tag"
		return 0
	else
		warn "Failed to pull pre-built image, building locally..."
		return 1
	fi
}

list_old_cco_image_refs() {
	local current_tag="$1"
	local image_ref

	while IFS= read -r image_ref; do
		if [[ "$image_ref" == "$current_tag" || "$image_ref" == "ghcr.io/nikvdp/cco:<none>" ]]; then
			continue
		fi

		case "$image_ref" in
		ghcr.io/nikvdp/cco:*)
			printf '%s\n' "$image_ref"
			;;
		esac
	done < <(docker image ls ghcr.io/nikvdp/cco --format '{{.Repository}}:{{.Tag}}' 2>/dev/null)
}

confirm_default_no() {
	local prompt="$1"

	if [[ -t 0 && -t 1 ]]; then
		echo
		read -p "$prompt [y/N] " -r
		if [[ $REPLY =~ ^([Yy])$ ]]; then
			return 0
		fi
	fi

	return 1
}

remove_old_cco_images() {
	local image_ref
	local failed=false

	for image_ref in "$@"; do
		log "Removing old cco image tag: $image_ref"
		if ! docker image rm "$image_ref" >/dev/null 2>&1; then
			warn "Could not remove old cco image tag: $image_ref"
			failed=true
		fi
	done

	[[ "$failed" == false ]]
}

offer_old_cco_image_cleanup() {
	local current_tag="$1"
	local image_ref
	local old_image_refs=()

	while IFS= read -r image_ref; do
		[[ -n "$image_ref" ]] && old_image_refs+=("$image_ref")
	done < <(list_old_cco_image_refs "$current_tag")

	if [[ ${#old_image_refs[@]} -eq 0 ]]; then
		return 0
	fi

	warn "Found ${#old_image_refs[@]} old cco Docker image tag(s) from previous pulls"
	for image_ref in "${old_image_refs[@]}"; do
		warn "  $image_ref"
	done

	if [[ "$clean_old_images" == true ]]; then
		remove_old_cco_images "${old_image_refs[@]}"
		return
	fi

	if confirm_default_no "Remove these old cco Docker image tags now?"; then
		remove_old_cco_images "${old_image_refs[@]}"
	else
		log "Keeping old cco Docker image tags"
		log "Use --clean-old-images with pull or --pull to remove them automatically after a successful pull"
	fi
}

# Build Docker image
build_image() {
	local original_dir="$PWD"

	log "Building cco Docker image..."

	# Build from the directory containing the cco script
	cd "$CCO_INSTALLATION_DIR" || {
		error "cco installation not found at $CCO_INSTALLATION_DIR"
		error "Run: curl -fsSL https://raw.githubusercontent.com/nikvdp/cco/master/install.sh | bash"
		exit 1
	}

	local build_args=()

	# Add custom packages if specified
	if [[ ${#custom_packages[@]} -gt 0 ]]; then
		local packages_list
		packages_list=$(
			IFS=' '
			echo "${custom_packages[*]}"
		)
		log "Installing additional packages: $packages_list"
		build_args+=(--build-arg CUSTOM_PACKAGES="$packages_list")
	fi

	# Check for custom Dockerfile in XDG config directory
	local custom_dockerfile="${XDG_CONFIG_HOME:-$HOME/.config}/cco/Dockerfile"
	local dockerfile_arg=""

	if [[ -f "$custom_dockerfile" ]]; then
		log "Using custom Dockerfile: $custom_dockerfile"
		dockerfile_arg=("-f" "$custom_dockerfile")
	else
		log "Using default Dockerfile"
		dockerfile_arg=("-f" "Dockerfile")
	fi

	# Add cache-busting argument to force Claude Code reinstallation on --rebuild
	build_args+=(--build-arg CACHE_BUST="$(date +%s)")

	# Use cache-from if we have a local pre-built image available
	local prebuilt_image_tag
	prebuilt_image_tag=$(get_prebuilt_image_tag)
	if docker image inspect "$prebuilt_image_tag" &>/dev/null; then
		log "Using local pre-built image for build cache: $prebuilt_image_tag"
		build_args+=(--cache-from "$prebuilt_image_tag")
	fi

	docker build -t "$IMAGE_NAME" "${build_args[@]}" "${dockerfile_arg[@]}" .
	cd "$original_dir"
	log "Image built successfully"
}

# Update cco installation
update_cco() {
	if [[ ! -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		error "cco installation not found at $CCO_INSTALLATION_DIR"
		error "Run: curl -fsSL https://raw.githubusercontent.com/nikvdp/cco/master/install.sh | bash"
		exit 1
	fi

	local original_dir="$PWD"
	cd "$CCO_INSTALLATION_DIR"

	log "Updating cco installation..."

	# Check for local modifications
	if ! git diff --quiet HEAD 2>/dev/null; then
		warn "WARNING: Your cco installation has local modifications."
		warn "Most users should reset to the latest version (this is safe)."
		warn "Only say 'no' if you've customized cco yourself."
		echo
		read -p "Reset to latest version and lose local changes? [Y/n] " -n 1 -r
		echo
		if [[ $REPLY =~ ^[Nn]$ ]]; then
			warn "Skipping update to preserve local changes"
			cd "$original_dir"
			return 1
		fi
		log "Resetting to latest version..."
		git reset --hard origin/master
	fi

	git fetch origin
	git pull origin master
	local new_version
	new_version=$(git rev-parse --short HEAD)
	log "Updated to $new_version"

	cd "$original_dir"
	log "Update complete!"
}

# Show version information
show_version() {
	if [[ -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		local version
		version=$(cd "$CCO_INSTALLATION_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
		local install_type="installation"
	else
		local version="dev"
		local install_type="development"
	fi

	echo "cco $version ($install_type)"
	echo "Installation: $CCO_INSTALLATION_DIR"
}

# Show comprehensive system information and status
show_info() {
	echo "cco - System Information & Status"
	echo "=================================="
	echo

	# Version info
	if [[ -d "$CCO_INSTALLATION_DIR/.git" ]]; then
		local version
		version=$(cd "$CCO_INSTALLATION_DIR" && git rev-parse --short HEAD 2>/dev/null || echo "unknown")
		local install_type="installation"
		local git_status
		git_status=$(cd "$CCO_INSTALLATION_DIR" && git status --porcelain 2>/dev/null)
	else
		local version="dev"
		local install_type="development"
		local git_status=""
	fi

	echo "📦 cco Information:"
	echo "  Version: $version ($install_type)"
	echo "  Location: $CCO_INSTALLATION_DIR"
	if [[ -n "$git_status" ]]; then
		echo "  Git Status: Modified (local changes present)"
	elif [[ "$install_type" == "installation" ]]; then
		echo "  Git Status: Clean"
	fi
	echo

	# Docker status
	echo "🐳 Docker Status:"
	if command -v docker &>/dev/null; then
		echo "  Docker CLI: ✓ Available"
		if docker info &>/dev/null; then
			local docker_version
			docker_version=$(docker version --format '{{.Server.Version}}' 2>/dev/null || echo "unknown")
			echo "  Docker Daemon: ✓ Running (v$docker_version)"

			# Check if our image exists
			if docker image inspect "$IMAGE_NAME" &>/dev/null; then
				local image_created
				image_created=$(docker image inspect "$IMAGE_NAME" --format '{{.Created}}' | cut -d'T' -f1)
				if using_custom_docker_image; then
					echo "  Docker Image: ✓ Available ($IMAGE_NAME, $image_created)"
				else
					echo "  cco Image: ✓ Built ($image_created)"
				fi
			else
				if using_custom_docker_image; then
					echo "  Docker Image: ✗ Not present locally ($IMAGE_NAME)"
				else
					echo "  cco Image: ✗ Not built (run with --rebuild)"
				fi
			fi
		else
			echo "  Docker Daemon: ✗ Not running"
		fi
	else
		echo "  Docker CLI: ✗ Not installed"
	fi
	echo

	# Claude Code authentication status
	echo "🤖 Claude Code Status:"
	if command -v claude &>/dev/null; then
		local claude_version
		claude_version=$(claude --version 2>/dev/null | head -1 || echo "unknown")
		echo "  Claude CLI: ✓ Available ($claude_version)"

		# Check authentication
		local claude_config_dir
		claude_config_dir=$(find_claude_config_dir)
		if [[ -d "$claude_config_dir" ]]; then
			echo "  Config Directory: ✓ Found ($claude_config_dir)"

			# Check credentials
			local auth_status="✗ Not authenticated"
			if command -v security &>/dev/null; then
				if capture_macos_keychain_credentials; then
					auth_status="✓ Authenticated (Keychain)"
				elif [[ -f "$claude_config_dir/.credentials.json" ]]; then
					auth_status="✓ Authenticated (File)"
				fi
			elif [[ -f "$claude_config_dir/.credentials.json" ]]; then
				auth_status="✓ Authenticated (File)"
			fi
			echo "  Authentication: $auth_status"
		else
			echo "  Config Directory: ✗ Not found"
			echo "  Authentication: ✗ Not configured"
		fi
	else
		echo "  Claude CLI: ✗ Not installed"
		echo "  Authentication: ✗ Cannot check"
	fi
	echo

	# System info
	echo "💻 System Information:"
	echo "  OS: $(uname -s) $(uname -r)"
	echo "  Architecture: $(uname -m)"
	echo "  User: $(whoami)"
	echo "  UID/GID: $(id -u):$(id -g)"
	echo

	# Overall status
	echo "🎯 Overall Status:"
	local ready=true
	local issues=()

	if ! command -v docker &>/dev/null; then
		ready=false
		issues+=("Docker not installed")
	elif ! docker info &>/dev/null; then
		ready=false
		issues+=("Docker daemon not running")
	fi

	if ! command -v claude &>/dev/null; then
		ready=false
		issues+=("Claude Code not installed")
	else
		local claude_config_dir
		claude_config_dir=$(find_claude_config_dir)
		if [[ ! -d "$claude_config_dir" ]]; then
			ready=false
			issues+=("Claude Code not configured")
		else
			local auth_ok=false
			if command -v security &>/dev/null; then
				if capture_macos_keychain_credentials; then
					auth_ok=true
				elif [[ -f "$claude_config_dir/.credentials.json" ]]; then
					auth_ok=true
				fi
			elif [[ -f "$claude_config_dir/.credentials.json" ]]; then
				auth_ok=true
			fi
			if [[ "$auth_ok" = false ]]; then
				ready=false
				issues+=("Claude Code not authenticated")
			fi
		fi
	fi

	if [[ "$ready" = true ]]; then
		echo "  Status: ✓ Ready to use cco"
	else
		echo "  Status: ✗ Issues found"
		echo "  Issues:"
		for issue in "${issues[@]}"; do
			echo "    - $issue"
		done
	fi
}

# Run with native sandbox backend
run_native_sandbox() {
	local claude_config_dir
	claude_config_dir=$(find_claude_config_dir)
	local current_dir="$PWD"
	local project_claude_dir="$current_dir/.claude"

	log "Starting cco with native sandbox..."

	# Check if sandbox script exists
	local sandbox_script="$CCO_INSTALLATION_DIR/sandbox"
	if [[ ! -x "$sandbox_script" ]]; then
		error "Sandbox script not found or not executable: $sandbox_script"
		error "Falling back to Docker backend"
		SANDBOX_BACKEND="docker"
		check_docker_dependencies
		run_container
		return
	fi

	# Prepare sandbox access rules
	local sandbox_rules=()

	# Always allow writes to current project directory
	sandbox_rules+=("--write" "$current_dir")

	# Add any additional directories specified with --add-dir
	for dir in "${additional_dirs[@]}"; do
		if [[ -d "$dir" ]]; then
			sandbox_rules+=("--write" "$dir")
			log "Adding additional directory: $dir"
		fi
	done

	# Allow read-write access to the entire ~/.claude directory
	# This is needed for state files, MCP configs, session data, etc.
	# Even if config is in ~/.config/claude, Claude may need to write to ~/.claude
	if [[ ! -d "$HOME/.claude" ]]; then
		mkdir -p "$HOME/.claude"
	fi
	sandbox_rules+=("--write" "$HOME/.claude")

	# Also allow the detected config directory if it's different from ~/.claude
	if [[ "$claude_config_dir" != "$HOME/.claude" ]]; then
		sandbox_rules+=("--write" "$claude_config_dir")
	fi

	# Allow access to main .claude.json file (Claude needs to write to this)
	# This is a specific file in the home directory, NOT inside ~/.claude/
	# Create it if it doesn't exist so the sandbox can whitelist it
	if [[ ! -f "$HOME/.claude.json" ]]; then
		echo "{}" >"$HOME/.claude.json"
	fi
	sandbox_rules+=("--write" "$HOME/.claude.json")

	# Allow access to .claude.json.lock directory used by Claude's atomic-write
	# library (steno/write-file-atomic). Without this, mkdir fails with EROFS
	# in the bwrap sandbox since $HOME is read-only. See #23.
	if [[ ! -d "$HOME/.claude.json.lock" ]]; then
		mkdir -p "$HOME/.claude.json.lock"
	fi
	sandbox_rules+=("--write" "$HOME/.claude.json.lock")

	# Allow writes to ~/.npm for MCP server operations (npm cache/logs)
	if [[ ! -d "$HOME/.npm" ]]; then
		mkdir -p "$HOME/.npm"
	fi
	sandbox_rules+=("--write" "$HOME/.npm")

	# Allow writes to project-specific .claude directory
	if [[ -d "$project_claude_dir" ]]; then
		sandbox_rules+=("--write" "$project_claude_dir")
	fi

	# Allow writes to temp directory for credential syncing
	sandbox_rules+=("--write" "/tmp")

	# Apply read-only and deny rules from CLI
	for ro_path in "${additional_ro_paths[@]}"; do
		sandbox_rules+=("--read-only" "$ro_path")
		log "Adding read-only path: $ro_path"
	done

	for blocked_path in "${deny_paths[@]}"; do
		sandbox_rules+=("--deny" "$blocked_path")
		log "Denying path inside sandbox: $blocked_path"
	done

	# On macOS, Claude needs to access the Keychain directly
	# The sandbox-exec Seatbelt profile already allows default system operations
	# including Keychain access, so we don't need to pre-extract credentials

	# On Linux with bubblewrap, credentials are in files so no special handling needed

	# Build the command
	local cmd=("$sandbox_script")
	if [[ "$safe_mode" = true ]]; then
		cmd+=("--safe")
	fi
	if [[ "$allow_keychain" = true ]]; then
		cmd+=("--allow-keychain")
	fi
	cmd+=("${sandbox_rules[@]}")

	# Add separator and any extra backend args (from -- or CCO_SANDBOX_ARGS_FILE)
	# Format: sandbox [opts] -- [backend-args...] -- <command>
	# The sandbox script collects everything between the two -- markers as backend args
	if [[ ${#sandbox_extra_args[@]} -gt 0 ]]; then
		cmd+=("--" "${sandbox_extra_args[@]}" "--")
		log "Adding ${#sandbox_extra_args[@]} extra sandbox backend args"
	fi

	# Debug: Show the full sandbox command being executed
	if [[ "${CCO_DEBUG:-}" == "1" ]]; then
		log "DEBUG: Sandbox command: ${cmd[*]}"
	fi

	# Get command to use and split into array
	local cmd_str
	cmd_str=$(get_command)
	# Split command string into array (handles multi-word commands)
	read -ra cmd_array <<<"$cmd_str"

	# Add command
	if [[ "$shell_mode" = true ]]; then
		if [[ ${#claude_args[@]} -eq 0 ]]; then
			# Interactive shell mode - use user's preferred shell
			cmd+=("${SHELL:-bash}")
		else
			# Shell command mode
			cmd+=("bash" "-c" "${claude_args[*]}")
		fi
	else
		# Check if we're running a custom command (CCO_COMMAND or --command)
		if [[ -n "$command_flag" || -n "$CCO_COMMAND" ]]; then
			# Running custom command - pass arguments as-is, no Claude-specific flags
			if [[ ${#claude_args[@]} -eq 0 ]]; then
				cmd+=("${cmd_array[@]}")
			else
				cmd+=("${cmd_array[@]}" "${claude_args[@]}")
			fi
		else
			# Running Claude - use --dangerously-skip-permissions since we're in a sandbox
			if [[ ${#claude_args[@]} -eq 0 ]]; then
				cmd+=("${cmd_array[@]}" "--dangerously-skip-permissions")
			else
				cmd+=("${cmd_array[@]}" "--dangerously-skip-permissions" "${claude_args[@]}")
			fi
		fi
	fi

	# Load .env file first (matching Docker backend behavior)
	if [[ -f ".env" ]]; then
		while IFS= read -r line || [[ -n "$line" ]]; do
			# Match Docker-style comment handling by ignoring leading whitespace.
			local trimmed_line="${line#"${line%%[![:space:]]*}"}"
			[[ -z "$trimmed_line" || "$trimmed_line" == \#* ]] && continue
			[[ "$trimmed_line" != *"="* ]] && continue
			local env_key="${line%%=*}"
			local env_val="${line#*=}"
			export "${env_key}=${env_val}"
		done <".env"
	fi

	# Apply custom environment variables after .env so -e flags take precedence
	for custom_env in "${custom_env_vars[@]}"; do
		if [[ "$custom_env" == *"="* ]]; then
			local env_key="${custom_env%%=*}"
			local env_val="${custom_env#*=}"
			export "${env_key}=${env_val}"
		else
			# KEY-only format: pass through from host environment
			if [[ -n "${!custom_env}" ]]; then
				export "${custom_env}=${!custom_env}"
			fi
		fi
	done

	# Execute in sandbox with full environment
	exec "${cmd[@]}"
}

# Main run function (Docker backend)
run_container() {
	local host_uid
	host_uid=$(id -u)
	local host_gid
	host_gid=$(id -g)
	local current_dir="$PWD"
	local persist_state_dir_path=""
	if [[ "$persist_mode" == true && -z "$persist_container_target" ]]; then
		persist_state_dir_path=$(persist_state_dir)
		mkdir -p "$persist_state_dir_path"
	fi

	log "Starting cco container..."

	# Detect if we have a TTY
	local tty_flag=""
	if [[ -t 0 && -t 1 ]]; then
		tty_flag="-it"
	fi

	local docker_args=(
		--init
		--name "$CONTAINER_NAME"
		--user "root"
		-e "HOST_UID=${host_uid}"
		-e "HOST_GID=${host_gid}"
		-v "$current_dir":"$current_dir"
		-w "$current_dir"
	)
	if [[ "$persist_mode" != true ]]; then
		docker_args=(--rm "${docker_args[@]}")
	fi

	# Add docker mount with destination de-duplication.
	# If the target is already mounted read-only and a later mount requests
	# read-write access, upgrade the existing mount to read-write.
	mount_target_from_spec() {
		local spec="$1"
		local after_source="${spec#*:}"
		printf '%s\n' "${after_source%%:*}"
	}

	find_mount_spec_index() {
		local target="$1"
		local i=0
		while [[ $i -lt ${#docker_args[@]} ]]; do
			if [[ "${docker_args[$i]}" == "-v" ]]; then
				local spec="${docker_args[$((i + 1))]}"
				local existing_target
				existing_target=$(mount_target_from_spec "$spec")
				if [[ "$existing_target" == "$target" ]]; then
					echo "$((i + 1))"
					return 0
				fi
				((i += 2))
			else
				((i += 1))
			fi
		done
		return 1
	}

	add_mount_arg() {
		local source="$1"
		local target="$2"
		local mode="${3:-rw}"
		local mount_spec="$source:$target"
		if [[ "$mode" == "ro" ]]; then
			mount_spec="$mount_spec:ro"
		fi

		local existing_index
		if existing_index=$(find_mount_spec_index "$target"); then
			local existing_spec="${docker_args[$existing_index]}"
			local existing_mode="rw"
			if [[ "$existing_spec" == *":ro" ]]; then
				existing_mode="ro"
			fi

			if [[ "$mode" == "rw" && "$existing_mode" == "ro" ]]; then
				docker_args[existing_index]="$source:$target"
				warn "Upgrading duplicate mount to read-write for $target"
				return 0
			fi

			if [[ "$existing_spec" == "$mount_spec" ]]; then
				warn "Skipping duplicate mount for $target"
			else
				warn "Skipping conflicting mount for $target (keeping existing mount)"
			fi
			return 0
		fi

		docker_args+=(-v "$mount_spec")
	}

	find_named_container_id() {
		docker ps -aq -f "name=^${CONTAINER_NAME}$"
	}

	container_is_running() {
		[[ -n "$(docker ps -q -f "name=^${CONTAINER_NAME}$")" ]]
	}

	resolve_persist_target_container_name() {
		local target="$1"
		local container_name
		container_name=$(docker inspect -f '{{.Name}}' "$target" 2>/dev/null || true)
		if [[ -z "$container_name" ]]; then
			error "Persistent container not found: $target"
			return 1
		fi
		printf '%s\n' "${container_name#/}"
	}

	# Determine the target user's home directory in container
	local container_home="/home/hostuser"
	local container_path="$container_home/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
	local persistent_exec_path="$container_path"
	docker_args+=(
		-e "HOME=$container_home"
		-e "PATH=$container_path"
	)

	# Determine Codex config directory mapping for Docker codex-mode sessions.
	# This ensures Codex auth/state resolves to the mounted directory even when
	# commands run with a different HOME (for example root inside container).
	local host_codex_home="${CODEX_HOME:-$HOME/.codex}"
	local resolved_host_codex_home
	resolved_host_codex_home=$(resolve_path "$host_codex_home")
	local container_codex_home="$resolved_host_codex_home"
	if [[ "$resolved_host_codex_home" == "$HOME"/* ]]; then
		local codex_relative="${resolved_host_codex_home#"$HOME"/}"
		container_codex_home="$container_home/$codex_relative"
	fi

	# Mount any additional directories specified with --add-dir
	# Remap $HOME-relative paths to $container_home inside the container
	# so agents can find their config dirs (e.g. ~/.codex → /home/hostuser/.codex)
	for dir in "${additional_dirs[@]}"; do
		if [[ -d "$dir" ]]; then
			if [[ -n "$git_worktree_common_dir" && "$dir" == "$git_worktree_common_dir" ]]; then
				add_mount_arg "$dir" "$dir"
				log "Mounting additional directory: $dir"
			elif [[ "$dir" == "$HOME"/* ]]; then
				local relative="${dir#"$HOME"/}"
				local container_dir="$container_home/$relative"
				add_mount_arg "$dir" "$container_dir"
				log "Mounting additional directory: $dir → $container_dir"
			else
				add_mount_arg "$dir" "$dir"
				log "Mounting additional directory: $dir"
			fi
		fi
	done

	# Track temporary overlays for deny paths
	local docker_cleanup_paths=()
	cleanup_docker_overlays() {
		for p in "${docker_cleanup_paths[@]}"; do
			if [[ -n "$p" && -e "$p" ]]; then
				rm -rf "$p"
			fi
		done
	}

	create_deny_overlay_source() {
		local blocked_path="$1"
		local overlay_path=""
		if [[ "$persist_mode" == true && -z "$persist_container_target" ]]; then
			local deny_hash
			deny_hash=$(hash_string "$blocked_path")
			overlay_path="$persist_state_dir_path/deny/$deny_hash"
			mkdir -p "$(dirname "$overlay_path")"
			if [[ -d "$blocked_path" ]]; then
				mkdir -p "$overlay_path"
			else
				: >"$overlay_path"
			fi
		elif [[ -d "$blocked_path" ]]; then
			overlay_path=$(mktemp -d)
			docker_cleanup_paths+=("$overlay_path")
		else
			overlay_path=$(mktemp)
			: >"$overlay_path"
			docker_cleanup_paths+=("$overlay_path")
		fi
		printf '%s\n' "$overlay_path"
	}

	# In codex mode, mount a PATH shim so nested `codex` calls run with
	# bypass mode inside cco's outer sandbox.
	if [[ "$codex_mode" == true ]]; then
		local codex_shim_dir
		if [[ "$persist_mode" == true && -z "$persist_container_target" ]]; then
			codex_shim_dir="$persist_state_dir_path/codex-shim"
			if [[ ! -x "$codex_shim_dir/codex" ]]; then
				local temp_codex_shim_dir
				temp_codex_shim_dir=$(create_codex_mode_shim_dir)
				mkdir -p "$codex_shim_dir"
				cp -R "$temp_codex_shim_dir"/. "$codex_shim_dir"/
				rm -rf "$temp_codex_shim_dir"
			fi
		else
			codex_shim_dir=$(create_codex_mode_shim_dir)
			docker_cleanup_paths+=("$codex_shim_dir")
		fi
		add_mount_arg "$codex_shim_dir" "$codex_shim_dir" "ro"
		docker_args+=(-e "CCO_PREPEND_PATH=$codex_shim_dir")
		persistent_exec_path="$codex_shim_dir:$persistent_exec_path"
		log "Enabled codex-mode PATH shim for nested codex invocations"
	fi

	# Apply read-only mounts
	for ro_path in "${additional_ro_paths[@]}"; do
		if [[ -d "$ro_path" ]]; then
			add_mount_arg "$ro_path" "$ro_path" "ro"
		elif [[ -f "$ro_path" ]]; then
			add_mount_arg "$ro_path" "$ro_path" "ro"
		else
			warn "Skipping read-only mount (path disappeared): $ro_path"
		fi
		log "Mounting read-only path: $ro_path"
	done

	# Apply deny overlays by mounting empty temp locations
	for blocked_path in "${deny_paths[@]}"; do
		local tmp_overlay
		if [[ -d "$blocked_path" ]]; then
			tmp_overlay=$(create_deny_overlay_source "$blocked_path")
			add_mount_arg "$tmp_overlay" "$blocked_path" "ro"
		elif [[ -f "$blocked_path" ]]; then
			tmp_overlay=$(create_deny_overlay_source "$blocked_path")
			add_mount_arg "$tmp_overlay" "$blocked_path" "ro"
		else
			warn "Skipping deny overlay (path disappeared): $blocked_path"
			continue
		fi
		log "Denying path inside container: $blocked_path"
	done

	# Detect host timezone and set container timezone
	local host_timezone=""
	if [[ -f /etc/timezone ]]; then
		# Linux: Read from /etc/timezone
		host_timezone=$(cat /etc/timezone)
	elif [[ -L /etc/localtime ]]; then
		# Linux/macOS: Extract from /etc/localtime symlink
		host_timezone=$(readlink /etc/localtime | sed 's|.*/zoneinfo/||')
	elif command -v timedatectl &>/dev/null; then
		# systemd systems: Use timedatectl
		host_timezone=$(timedatectl show --property=Timezone --value 2>/dev/null)
	elif [[ -f /etc/localtime ]]; then
		# Fallback: Try to determine timezone from /etc/localtime
		# This is more complex and may not always work reliably
		host_timezone=$(find /usr/share/zoneinfo -type f -exec cmp -s {} /etc/localtime \; -print | head -1 | sed 's|.*/zoneinfo/||')
	fi

	# Pass through relevant environment variables
	local env_vars=(
		# Anthropic / Claude Code
		"ANTHROPIC_API_KEY"
		"ANTHROPIC_BASE_URL"
		"CLAUDE_CODE_OAUTH_TOKEN"
		"CLAUDE_CONFIG_DIR"
		# OpenAI / Codex
		"OPENAI_API_KEY"
		# Google / Gemini
		"GEMINI_API_KEY"
		"GOOGLE_API_KEY"
		"GOOGLE_CLOUD_PROJECT"
		"GOOGLE_CLOUD_LOCATION"
		"GOOGLE_APPLICATION_CREDENTIALS"
		# Factory / Droid
		"FACTORY_API_KEY"
		# Agent config dir overrides
		"CODEX_HOME"
		"PI_CODING_AGENT_DIR"
		"GEMINI_SANDBOX"
		# Other LLM providers (used by pi, opencode, etc.)
		"GROQ_API_KEY"
		"MISTRAL_API_KEY"
		"XAI_API_KEY"
		"OPENROUTER_API_KEY"
		"CEREBRAS_API_KEY"
		"HUGGINGFACE_API_KEY"
		"AI_GATEWAY_API_KEY"
		# Chinese model providers
		"MOONSHOT_API_KEY"
		"KIMI_API_KEY"
		"ZHIPU_API_KEY"
		"ZAI_API_KEY"
		"MINIMAX_API_KEY"
		"DASHSCOPE_API_KEY"
		"QWEN_API_KEY"
		# Terminal / locale / proxy
		"XDG_CONFIG_HOME"
		"NO_COLOR"
		"TERM"
		"COLORTERM"
		"LANG"
		"LC_ALL"
		"HTTP_PROXY"
		"HTTPS_PROXY"
		"NO_PROXY"
		"GIT_AUTHOR_NAME"
		"GIT_AUTHOR_EMAIL"
		"GIT_COMMITTER_NAME"
		"GIT_COMMITTER_EMAIL"
	)

	for var in "${env_vars[@]}"; do
		if [[ -n "${!var}" ]]; then
			docker_args+=(-e "$var=${!var}")
		fi
	done

	# Set timezone in container
	if [[ -n "$host_timezone" ]]; then
		log "Setting container timezone to: $host_timezone"
		docker_args+=(-e "TZ=$host_timezone")
	elif [[ -n "$TZ" ]]; then
		# Use TZ environment variable if set
		docker_args+=(-e "TZ=$TZ")
	fi

	# Add custom environment variables from command line
	for custom_env in "${custom_env_vars[@]}"; do
		if [[ "$custom_env" == *"="* ]]; then
			# KEY=VALUE format
			docker_args+=(-e "$custom_env")
		else
			# KEY format - pass through from host environment
			if [[ -n "${!custom_env}" ]]; then
				docker_args+=(-e "$custom_env=${!custom_env}")
			fi
		fi
	done

	# Ensure Codex resolves auth/state from the mounted directory in codex-mode.
	if [[ "$codex_mode" == true ]]; then
		docker_args+=(-e "CODEX_HOME=$container_codex_home")
		log "Setting CODEX_HOME in container: $container_codex_home"
	fi

	# Load .env file if it exists
	[[ -f ".env" ]] && docker_args+=(--env-file .env)

	# Enable Claude Code background tasks when requested (can be enabled with --enable-background-tasks)
	if [[ "$enable_background_tasks" = true ]]; then
		docker_args+=(-e "ENABLE_BACKGROUND_TASKS=1")
	fi

	# Enable Docker access if requested
	if [[ "$docker_access" = true ]]; then
		# Check for Docker socket locations (Linux and macOS with Docker Desktop)
		if [[ -S "/var/run/docker.sock" ]]; then
			log "Enabling Docker access via /var/run/docker.sock"
			add_mount_arg "/var/run/docker.sock" "/var/run/docker.sock"
		elif [[ -S "$HOME/.docker/run/docker.sock" ]]; then
			log "Enabling Docker access via $HOME/.docker/run/docker.sock"
			add_mount_arg "$HOME/.docker/run/docker.sock" "/var/run/docker.sock"
		else
			warn "Docker socket not found - Docker access may not work"
			warn "Tried: /var/run/docker.sock, $HOME/.docker/run/docker.sock"
		fi
	fi

	# Configure container networking for MCP server access
	setup_container_networking() {
		local use_host_networking=false
		local networking_method=""

		# Check if Docker daemon supports host networking by looking for host network driver
		if [[ "$force_bridge_network" = true ]]; then
			networking_method="Docker bridge networking (forced via --force-docker-bridge-network)"
		elif docker network ls --format "{{.Driver}}" 2>/dev/null | grep -q "^host$"; then
			use_host_networking=true
			networking_method="Docker host networking"
		else
			networking_method="Docker bridge networking (host not available)"
		fi

		if [[ "$use_host_networking" = true ]]; then
			docker_args+=(--network=host)
			log "Using host networking for MCP server access ($networking_method)"
		else
			docker_args+=(--add-host=host.docker.internal:host-gateway)
			networking_method="host.docker.internal bridge"
			log "Using bridge networking ($networking_method)"

			# Warn about MCP server connectivity limitations
			if [[ -d "$HOME/.claude" && $(find "$HOME/.claude" -name "*.json" -exec grep -l "localhost\|127\.0\.0\.1" {} \; 2>/dev/null | wc -l) -gt 0 ]]; then
				warn "Detected Claude configs referencing localhost - MCP servers may not be accessible"
				warn "Consider upgrading to Docker Desktop 4.34+ or using OrbStack for full MCP server support"
				warn "Alternative: Reconfigure MCP servers to use host.docker.internal instead of localhost"
			fi
		fi
	}

	setup_container_networking

	# Set up Claude Code configuration in container
	local host_system_claude_dir
	host_system_claude_dir=$(find_claude_config_dir)
	local project_claude_dir="$current_dir/.claude"

	# container_home already set above (for additional_dirs remapping)

	# Let Claude Code auto-detect its config directory (don't override with CLAUDE_CONFIG_DIR)

	# Create temporary directory for credentials extraction
	local temp_creds_dir
	if [[ "$persist_mode" == true && -z "$persist_container_target" ]]; then
		temp_creds_dir="$persist_state_dir_path/creds"
		mkdir -p "$temp_creds_dir"
	else
		temp_creds_dir=$(mktemp -d)
	fi
	local original_creds_content=""
	local host_creds_file=""
	local startup_system_creds_content=""
	local stop_persistent_container_on_exit=false

	# Setup cleanup and credentials sync-back on exit
	if [[ "$allow_oauth_refresh" = true ]]; then
		if [[ "$persist_mode" == true && -z "$persist_container_target" ]]; then
			trap 'stop_persistent_container_if_needed; sync_credentials_back "$temp_creds_dir" "$original_creds_content" "$host_creds_file" "$startup_system_creds_content"; cleanup_docker_overlays' EXIT
		else
			trap 'stop_persistent_container_if_needed; sync_credentials_back "$temp_creds_dir" "$original_creds_content" "$host_creds_file" "$startup_system_creds_content" && rm -rf "$temp_creds_dir"; cleanup_docker_overlays' EXIT
		fi
	else
		if [[ "$persist_mode" == true && -z "$persist_container_target" ]]; then
			trap 'stop_persistent_container_if_needed; cleanup_docker_overlays' EXIT
		else
			trap 'stop_persistent_container_if_needed; rm -rf "$temp_creds_dir"; cleanup_docker_overlays' EXIT
		fi
	fi

	# Ensure ~/.claude directory exists and mount it (read-write for state updates)
	# Claude needs to write to this directory for session data, MCP configs, etc.
	if [[ ! -d "$HOME/.claude" ]]; then
		mkdir -p "$HOME/.claude"
	fi
	log "Mounting ~/.claude directory: $HOME/.claude → $container_home/.claude"
	add_mount_arg "$HOME/.claude" "$container_home/.claude"

	# If the detected config directory is different from ~/.claude, mount it too
	if [[ "$host_system_claude_dir" != "$HOME/.claude" ]]; then
		log "Also mounting config directory: $host_system_claude_dir → $container_home/.config/claude"
		# Create the parent directory in the mount command
		add_mount_arg "$host_system_claude_dir" "$container_home/.config/claude"
	fi

	# Extract fresh credentials from macOS, preferring Keychain but falling back
	# to a plaintext credentials file when that's what Claude is using.
	if command -v security &>/dev/null; then
		local keychain_creds credentials_file
		credentials_file="$host_system_claude_dir/.credentials.json"
		if capture_macos_keychain_credentials; then
			keychain_creds="$keychain_credentials_payload"
		else
			keychain_creds=""
		fi
		if [[ -n "$keychain_creds" ]]; then
			echo "$keychain_creds" >"$temp_creds_dir/.credentials.json"
			chmod 600 "$temp_creds_dir/.credentials.json"

			# Store original content for sync-back detection if --allow-oauth-refresh enabled
			if [[ "$allow_oauth_refresh" = true ]]; then
				original_creds_content=$(cat "$temp_creds_dir/.credentials.json")
				startup_system_creds_content="$keychain_creds"
				host_creds_file="" # macOS uses Keychain, not file
			fi

			# Mount credentials with appropriate permissions based on --allow-oauth-refresh
			if [[ "$allow_oauth_refresh" = true ]]; then
				add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json"
				log "Mounting fresh credentials from macOS Keychain (read-write for OAuth refresh)"
			else
				add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json" "ro"
				log "Mounting fresh credentials from macOS Keychain (read-only)"
			fi
		elif [[ -f "$credentials_file" ]]; then
			cp "$credentials_file" "$temp_creds_dir/.credentials.json"
			chmod 600 "$temp_creds_dir/.credentials.json"

			if [[ "$allow_oauth_refresh" = true ]]; then
				original_creds_content=$(cat "$temp_creds_dir/.credentials.json")
				startup_system_creds_content=$(cat "$credentials_file")
				host_creds_file="$credentials_file"
			fi

			if [[ "$allow_oauth_refresh" = true ]]; then
				add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json"
				log "Mounting credentials file from $credentials_file (read-write for OAuth refresh)"
			else
				add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json" "ro"
				log "Mounting credentials file from $credentials_file (read-only)"
			fi
		fi
	elif [[ -f "$host_system_claude_dir/.credentials.json" ]]; then
		# Linux: Copy from existing credentials file
		cp "$host_system_claude_dir/.credentials.json" "$temp_creds_dir/.credentials.json"
		chmod 600 "$temp_creds_dir/.credentials.json"

		# Store original content for sync-back detection if --allow-oauth-refresh enabled
		if [[ "$allow_oauth_refresh" = true ]]; then
			original_creds_content=$(cat "$temp_creds_dir/.credentials.json")
			startup_system_creds_content=$(cat "$host_system_claude_dir/.credentials.json")
			host_creds_file="$host_system_claude_dir/.credentials.json"
		fi

		# Mount credentials with appropriate permissions based on --allow-oauth-refresh
		if [[ "$allow_oauth_refresh" = true ]]; then
			add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json"
			log "Mounting credentials file (read-write for OAuth refresh)"
		else
			add_mount_arg "$temp_creds_dir/.credentials.json" "$container_home/.claude/.credentials.json" "ro"
			log "Mounting credentials file (read-only)"
		fi
	fi

	# Mount main .claude.json from home directory (this is separate from .claude/)
	# Create it if it doesn't exist to ensure Claude can write to it
	if [[ ! -f "$HOME/.claude.json" ]]; then
		echo "{}" >"$HOME/.claude.json"
	fi
	log "Mounting main .claude.json from home directory"
	add_mount_arg "$HOME/.claude.json" "$container_home/.claude.json"

	# Mount project-specific .claude directory (read-write for project settings)
	if [[ -d "$project_claude_dir" ]]; then
		log "Mounting project Claude config from $project_claude_dir (read-write)"
		add_mount_arg "$project_claude_dir" "$project_claude_dir"
	fi

	# Bind mount common config files
	[[ -f "$HOME/.gitconfig" ]] && add_mount_arg "$HOME/.gitconfig" "$container_home/.gitconfig" "ro"
	[[ -d "$HOME/.ssh" ]] && add_mount_arg "$HOME/.ssh" "$container_home/.ssh" "ro"

	# Add any extra sandbox args (from -- or CCO_SANDBOX_ARGS_FILE)
	if [[ ${#sandbox_extra_args[@]} -gt 0 ]]; then
		log "Adding ${#sandbox_extra_args[@]} extra sandbox args"
		docker_args+=("${sandbox_extra_args[@]}")
	fi

	compute_persist_config_hash() {
		persist_config_docker_args_signature() {
			local filtered_args=()
			local project_claude_mount="$current_dir/.claude:$current_dir/.claude"
			local current_dir_mount="$current_dir:$current_dir"
			local git_worktree_common_dir_mount=""
			if [[ -n "$git_worktree_common_dir" ]]; then
				git_worktree_common_dir_mount="$git_worktree_common_dir:$git_worktree_common_dir"
			fi
			local i=0

			while [[ $i -lt ${#docker_args[@]} ]]; do
				local arg="${docker_args[$i]}"
				case "$arg" in
				-v)
					local mount_spec="${docker_args[$((i + 1))]}"
					if [[ "$mount_spec" == "$current_dir_mount" || "$mount_spec" == "$project_claude_mount" || "$mount_spec" == "$git_worktree_common_dir_mount" ]]; then
						((i += 2))
						continue
					fi
					filtered_args+=("$arg" "$mount_spec")
					((i += 2))
					;;
				-w)
					local workdir_arg="${docker_args[$((i + 1))]}"
					if [[ "$workdir_arg" == "$current_dir" ]]; then
						((i += 2))
						continue
					fi
					filtered_args+=("$arg" "$workdir_arg")
					((i += 2))
					;;
				*)
					filtered_args+=("$arg")
					((i += 1))
					;;
				esac
			done

			printf 'docker_arg=%q\n' "${filtered_args[@]}"
		}

		local env_file_signature=""
		if [[ -f ".env" ]]; then
			env_file_signature=$(hash_string "$(cat .env)")
		fi
		local signature
		signature=$(
			printf 'image=%s\n' "$IMAGE_NAME"
			printf 'persist_scope_root=%s\n' "${persist_scope_root:-$current_dir}"
			printf 'host_uid=%s\n' "$host_uid"
			printf 'host_gid=%s\n' "$host_gid"
			printf 'docker_access=%s\n' "$docker_access"
			printf 'force_bridge_network=%s\n' "$force_bridge_network"
			printf 'allow_oauth_refresh=%s\n' "$allow_oauth_refresh"
			printf 'codex_mode=%s\n' "$codex_mode"
			printf 'custom_packages=%s\n' "${custom_packages[*]}"
			printf '.env=%s\n' "$env_file_signature"
			persist_config_docker_args_signature
		)
		hash_string "$signature"
	}

	# Function to start background SIGWINCH monitor
	start_sigwinch_monitor() {
		local container_name="$1"

		# Background process to monitor and forward SIGWINCH signals to container
		(
			# Wait for container to initialize
			sleep 2

			# Set up signal handler to forward SIGWINCH to container processes
			# shellcheck disable=SC2064  # Intentional: expand container_name at definition time
			trap "docker exec '$container_name' pkill -SIGWINCH -u hostuser 2>/dev/null" WINCH

			# Keep monitor alive while container exists
			while docker ps --format '{{.Names}}' | grep -q "^$container_name\$" 2>/dev/null; do
				sleep 2
			done
		) >/dev/null 2>&1 &
		echo $!
	}

	stop_persistent_container_if_needed() {
		if [[ "$stop_persistent_container_on_exit" != true ]]; then
			return 0
		fi

		if [[ -z "${CONTAINER_NAME:-}" ]]; then
			return 0
		fi

		if container_is_running; then
			log "Stopping persistent container: $CONTAINER_NAME"
			docker stop "$CONTAINER_NAME" >/dev/null || true
		fi
	}

	ensure_requested_workdir_is_available() {
		if docker exec \
			-u "${host_uid}:${host_gid}" \
			-e "HOME=$container_home" \
			-e "PATH=$persistent_exec_path" \
			"$CONTAINER_NAME" \
			sh -lc 'test -d "$1"' sh "$current_dir" >/dev/null 2>&1; then
			return 0
		fi

		error "Persistent container does not expose the current working directory: $current_dir"
		error "Use a different session, attach to another container, or recreate this container from a broader starting point."
		return 1
	}

	ensure_persistent_container() {
		local persist_config_hash="$1"
		local existing_container_id
		existing_container_id=$(find_named_container_id)

		if [[ -n "$existing_container_id" ]]; then
			local existing_config_hash
			existing_config_hash=$(docker inspect -f '{{ index .Config.Labels "cco.persist.config-hash" }}' "$CONTAINER_NAME" 2>/dev/null || echo "")
			if [[ "$existing_config_hash" != "$persist_config_hash" ]]; then
				error "Persistent container exists with a different configuration: $CONTAINER_NAME"
				error "Remove it with: docker rm -f $CONTAINER_NAME"
				return 1
			fi
			if container_is_running; then
				log "Reusing persistent container: $CONTAINER_NAME"
			else
				log "Starting persistent container: $CONTAINER_NAME"
				docker start "$CONTAINER_NAME" >/dev/null
			fi
			stop_persistent_container_on_exit=true
			return 0
		fi

		log "Creating persistent container: $CONTAINER_NAME"
		docker create \
			--label "cco.persist=1" \
			--label "cco.persist.config-hash=$persist_config_hash" \
			--label "cco.persist.state-dir=$persist_state_dir_path" \
			"${docker_args[@]}" \
			"$IMAGE_NAME" \
			sh -lc 'trap "exit 0" TERM INT; while :; do sleep 3600; done' >/dev/null
		log "Starting persistent container: $CONTAINER_NAME"
		docker start "$CONTAINER_NAME" >/dev/null
		stop_persistent_container_on_exit=true
	}

	run_persistent_command() {
		local sigwinch_monitor_pid=""
		local -a exec_args=(exec)
		if [[ -n "$tty_flag" ]]; then
			exec_args+=("$tty_flag")
		fi
		exec_args+=(
			-u "${host_uid}:${host_gid}"
			-e "HOME=$container_home"
			-e "PATH=$persistent_exec_path"
			-w "$current_dir"
			"$CONTAINER_NAME"
		)

		if ! ensure_requested_workdir_is_available; then
			return 1
		fi

		if [[ "$shell_mode" = true ]]; then
			if [[ ${#claude_args[@]} -eq 0 ]]; then
				if [[ -n "$tty_flag" ]]; then
					sigwinch_monitor_pid=$(start_sigwinch_monitor "$CONTAINER_NAME")
				fi
				docker "${exec_args[@]}" bash
			else
				docker "${exec_args[@]}" bash -c "${claude_args[*]}"
			fi
		else
			local cmd_str
			cmd_str=$(get_command)
			local cmd_array=()
			read -ra cmd_array <<<"$cmd_str"

			if [[ -n "$tty_flag" ]]; then
				sigwinch_monitor_pid=$(start_sigwinch_monitor "$CONTAINER_NAME")
			fi
			if [[ -n "$command_flag" || -n "$CCO_COMMAND" ]]; then
				docker "${exec_args[@]}" "${cmd_array[@]}" "${claude_args[@]}"
			else
				docker "${exec_args[@]}" "${cmd_array[@]}" --dangerously-skip-permissions "${claude_args[@]}"
			fi
		fi
		local exec_status=$?
		if [[ -n "$sigwinch_monitor_pid" ]]; then
			kill "$sigwinch_monitor_pid" 2>/dev/null || true
		fi
		return $exec_status
	}

	# Run the container (entrypoint will handle user setup)
	local run_status=0
	if [[ "$persist_mode" == true || -n "$persist_container_target" ]]; then
		if [[ -n "$persist_container_target" ]]; then
			CONTAINER_NAME=$(resolve_persist_target_container_name "$persist_container_target") || return 1
			if container_is_running; then
				log "Using persistent container: $CONTAINER_NAME"
			else
				log "Starting persistent container: $CONTAINER_NAME"
				docker start "$CONTAINER_NAME" >/dev/null
				stop_persistent_container_on_exit=true
			fi
		else
			local persist_config_hash
			persist_config_hash=$(compute_persist_config_hash)
			ensure_persistent_container "$persist_config_hash" || return 1
		fi
		if run_persistent_command; then
			run_status=0
		else
			run_status=$?
		fi
		stop_persistent_container_if_needed
		stop_persistent_container_on_exit=false
	else
		if [[ "$shell_mode" = true ]]; then
			if [[ ${#claude_args[@]} -eq 0 ]]; then
				# Interactive shell mode - Docker image may not have user's $SHELL
				local sigwinch_monitor_pid=""
				if [[ -n "$tty_flag" ]]; then
					sigwinch_monitor_pid=$(start_sigwinch_monitor "$CONTAINER_NAME")
				fi
				if [[ -n "$tty_flag" ]]; then
					docker run "$tty_flag" "${docker_args[@]}" "$IMAGE_NAME" bash
				else
					docker run "${docker_args[@]}" "$IMAGE_NAME" bash
				fi
				run_status=$?
				if [[ -n "$sigwinch_monitor_pid" ]]; then
					kill "$sigwinch_monitor_pid" 2>/dev/null || true
				fi
			else
				# Shell command mode
				docker run "${docker_args[@]}" "$IMAGE_NAME" bash -c "${claude_args[*]}"
				run_status=$?
			fi
		else
			local sigwinch_monitor_pid=""
			if [[ -n "$tty_flag" ]]; then
				sigwinch_monitor_pid=$(start_sigwinch_monitor "$CONTAINER_NAME")
			fi
			# Get command to use and split into array for Docker run too
			local cmd_str
			cmd_str=$(get_command)
			read -ra cmd_array <<<"$cmd_str"

			# Check if we're running a custom command (CCO_COMMAND or --command)
			if [[ -n "$command_flag" || -n "$CCO_COMMAND" ]]; then
				# Running custom command - pass arguments as-is, no Claude-specific flags
				if [[ -n "$tty_flag" ]]; then
					docker run "$tty_flag" "${docker_args[@]}" "$IMAGE_NAME" "${cmd_array[@]}" "${claude_args[@]}"
				else
					docker run "${docker_args[@]}" "$IMAGE_NAME" "${cmd_array[@]}" "${claude_args[@]}"
				fi
			else
				# Running Claude - use --dangerously-skip-permissions
				if [[ -n "$tty_flag" ]]; then
					docker run "$tty_flag" "${docker_args[@]}" "$IMAGE_NAME" "${cmd_array[@]}" --dangerously-skip-permissions "${claude_args[@]}"
				else
					docker run "${docker_args[@]}" "$IMAGE_NAME" "${cmd_array[@]}" --dangerously-skip-permissions "${claude_args[@]}"
				fi
			fi
			run_status=$?
			if [[ -n "$sigwinch_monitor_pid" ]]; then
				kill "$sigwinch_monitor_pid" 2>/dev/null || true
			fi
		fi
	fi
	cleanup_docker_overlays
	trap - EXIT
	return $run_status
}

# Backup Claude Code credentials to a safe location
backup_credentials() {
	local backup_dir="$HOME/.cco-backups"
	local timestamp
	timestamp=$(date +"%Y%m%d_%H%M%S")
	local backup_file="$backup_dir/claude-credentials.$timestamp.json"

	# Create backup directory if it doesn't exist
	mkdir -p "$backup_dir"

	log "Backing up Claude Code credentials..."

	if command -v security &>/dev/null; then
		# macOS: Extract from Keychain
		local keychain_creds claude_config_dir creds_file
		if capture_macos_keychain_credentials; then
			keychain_creds="$keychain_credentials_payload"
			echo "$keychain_creds" >"$backup_file"
			chmod 600 "$backup_file"
			log "Successfully backed up Keychain credentials to: $backup_file"
			echo "To restore: ./cco restore-creds \"$backup_file\""
		else
			claude_config_dir=$(find_claude_config_dir)
			creds_file="$claude_config_dir/.credentials.json"
			if [[ -f "$creds_file" ]]; then
				cp "$creds_file" "$backup_file"
				chmod 600 "$backup_file"
				log "Successfully backed up credentials file to: $backup_file"
				echo "To restore: ./cco restore-creds \"$backup_file\""
			else
				error "No Claude Code credentials found in macOS Keychain or at: $creds_file"
				exit 1
			fi
		fi
	else
		# Linux: Copy from credentials file
		local claude_config_dir
		claude_config_dir=$(find_claude_config_dir)
		local creds_file="$claude_config_dir/.credentials.json"

		if [[ -f "$creds_file" ]]; then
			cp "$creds_file" "$backup_file"
			chmod 600 "$backup_file"
			log "Successfully backed up credentials file to: $backup_file"
			echo "To restore: ./cco restore-creds \"$backup_file\""
		else
			error "No Claude Code credentials file found at: $creds_file"
			exit 1
		fi
	fi
}

# Restore Claude Code credentials from a backup
restore_credentials() {
	local backup_file="$1"
	local backup_dir="$HOME/.cco-backups"

	if [[ -z "$backup_file" ]]; then
		# Auto-select most recent backup
		if [[ ! -d "$backup_dir" ]]; then
			error "No backup directory found at: $backup_dir"
			echo "Run './cco backup-creds' first to create a backup"
			exit 1
		fi

		# Find the most recent backup file
		backup_file=$(find "$backup_dir" -name "claude-credentials.*.json" -not -name "*.pre-restore.*" -type f -print0 2>/dev/null | xargs -0 ls -t | head -1)

		if [[ -z "$backup_file" ]]; then
			error "No backup files found in: $backup_dir"
			echo "Run './cco backup-creds' first to create a backup"
			exit 1
		fi

		# Confirm with user
		echo "Most recent backup found: $(basename "$backup_file")"
		echo "Created: $(date -r "$backup_file" 2>/dev/null || stat -c %y "$backup_file" 2>/dev/null || echo "unknown")"
		echo
		read -p "Restore this backup? [y/N]: " -r
		if [[ ! $REPLY =~ ^[Yy]$ ]]; then
			echo "Restore cancelled"
			exit 0
		fi
	fi

	if [[ ! -f "$backup_file" ]]; then
		error "Backup file not found: $backup_file"
		exit 1
	fi

	log "Restoring Claude Code credentials from: $backup_file"

	# Create a backup of current credentials before restoring
	local current_backup_timestamp
	current_backup_timestamp=$(date +"%Y%m%d_%H%M%S")

	local claude_config_dir creds_file
	claude_config_dir=$(find_claude_config_dir)
	creds_file="$claude_config_dir/.credentials.json"

	if command -v security &>/dev/null && { capture_macos_keychain_credentials || [[ ! -f "$creds_file" ]]; }; then
		# macOS: Backup current and restore to Keychain
		log "Creating backup of current Keychain credentials..."
		local current_creds keychain_service keychain_account
		keychain_service=$(get_claude_keychain_service_name)
		keychain_account=$(get_claude_keychain_account)
		current_creds=$(security find-generic-password -s "$keychain_service" -a "$keychain_account" -w 2>/dev/null || echo "")
		if [[ -n "$current_creds" ]]; then
			local current_backup_dir="$HOME/.cco-backups"
			mkdir -p "$current_backup_dir"
			echo "$current_creds" >"$current_backup_dir/claude-credentials.pre-restore.$current_backup_timestamp.json"
			log "Current credentials backed up to: $current_backup_dir/claude-credentials.pre-restore.$current_backup_timestamp.json"
		fi

		# Restore from backup file
		local restore_creds
		restore_creds=$(cat "$backup_file")
		if security add-generic-password -U -s "$keychain_service" -a "$keychain_account" -w "$restore_creds" >/dev/null 2>&1; then
			log "Successfully restored credentials to macOS Keychain"
		else
			error "Failed to restore credentials to macOS Keychain"
			exit 1
		fi
	else
		# Linux: Backup current and restore to file
		# Backup current credentials if they exist
		if [[ -f "$creds_file" ]]; then
			local current_backup_file="${creds_file}.pre-restore.$current_backup_timestamp"
			cp "$creds_file" "$current_backup_file"
			log "Current credentials backed up to: $current_backup_file"
		fi

		# Restore from backup
		if cp "$backup_file" "$creds_file"; then
			chmod 600 "$creds_file"
			log "Successfully restored credentials to: $creds_file"
		else
			error "Failed to restore credentials to: $creds_file"
			exit 1
		fi
	fi
}

# Initialize variables
claude_args=()
additional_dirs=()
additional_ro_paths=()
deny_paths=()
custom_env_vars=()
custom_packages=()
sandbox_extra_args=()
git_worktree_common_dir=""
docker_access=false
allow_oauth_refresh=false
allow_keychain=false
enable_background_tasks=false
rebuild_image=false
pull_image=false
clean_old_images=false
yes_flag=false
shell_mode=false
safe_mode=false
persist_mode=false
persist_name_flag=""
persist_container_target=""
docker_image_override=""
force_bridge_network=false
allow_external_git_dir=false
enable_git_worktree_common_dir=true
claude_command_flag=""
command_flag=""
codex_mode=false

if [[ "${CCO_ALLOW_EXTERNAL_GIT_DIR:-}" == "1" ]]; then
	allow_external_git_dir=true
fi

# Load sandbox args from file if CCO_SANDBOX_ARGS_FILE is set
if [[ -n "${CCO_SANDBOX_ARGS_FILE:-}" ]]; then
	if [[ -f "$CCO_SANDBOX_ARGS_FILE" ]]; then
		while IFS= read -r line || [[ -n "$line" ]]; do
			# Skip empty lines and comments
			[[ -z "$line" || "$line" == \#* ]] && continue
			sandbox_extra_args+=("$line")
		done <"$CCO_SANDBOX_ARGS_FILE"
		log "Loaded ${#sandbox_extra_args[@]} sandbox args from $CCO_SANDBOX_ARGS_FILE"
	else
		warn "CCO_SANDBOX_ARGS_FILE set but file not found: $CCO_SANDBOX_ARGS_FILE"
	fi
fi

# Normalize --flag=value into --flag value for consistent parsing
# Only normalize args before --, passthrough args are left as-is
normalized_args=()
found_separator=false
for arg in "$@"; do
	if [[ "$arg" == "--" ]]; then
		found_separator=true
		normalized_args+=("$arg")
	elif [[ "$found_separator" == false && "$arg" == --persist=* ]]; then
		normalized_args+=("$arg")
	elif [[ "$found_separator" == false && "$arg" == --*=* ]]; then
		normalized_args+=("${arg%%=*}" "${arg#*=}")
	else
		normalized_args+=("$arg")
	fi
done
set -- "${normalized_args[@]}"

# First pass: Extract cco-specific flags and collect remaining args
# This ensures --add-dir and other cco flags are parsed before subcommands
remaining_args=()
while [[ $# -gt 0 ]]; do
	case $1 in
	--yes | -y)
		yes_flag=true
		shift
		;;
	--backend)
		if [[ $# -lt 2 ]]; then
			error "--backend requires an argument (auto, native, docker)"
			exit 1
		fi
		SANDBOX_BACKEND="$2"
		shift 2
		;;
	--rebuild)
		rebuild_image=true
		shift
		;;
	--pull)
		pull_image=true
		shift
		;;
	--clean-old-images)
		clean_old_images=true
		shift
		;;
	--docker-socket)
		docker_access=true
		shift
		;;
	--force-docker-bridge-network)
		force_bridge_network=true
		shift
		;;
	--persist)
		persist_mode=true
		if [[ $# -gt 1 ]] && [[ "$2" != -* ]] && ! is_known_subcommand "$2" && is_valid_persist_name "$2"; then
			persist_name_flag="$2"
			shift 2
		else
			shift
		fi
		;;
	--persist=*)
		persist_mode=true
		persist_name_flag="${1#*=}"
		if [[ -z "$persist_name_flag" ]]; then
			error "--persist requires a non-empty session name when using --persist=NAME"
			exit 1
		fi
		if ! is_valid_persist_name "$persist_name_flag"; then
			error "Invalid persist session name: $persist_name_flag"
			error "Use only letters, numbers, dot, underscore, or dash"
			exit 1
		fi
		shift
		;;
	--persist-container)
		if [[ $# -lt 2 ]]; then
			error "--persist-container requires a container name or ID"
			exit 1
		fi
		persist_container_target="$2"
		shift 2
		;;
	--image | --docker-image)
		if [[ $# -lt 2 ]]; then
			error "$1 requires a Docker image name"
			exit 1
		fi
		docker_image_override="$2"
		if [[ -z "$docker_image_override" ]]; then
			error "$1 requires a non-empty Docker image name"
			exit 1
		fi
		shift 2
		;;
	--allow-oauth-refresh)
		allow_oauth_refresh=true
		shift
		;;
	--allow-keychain)
		allow_keychain=true
		shift
		;;
	--enable-background-tasks)
		enable_background_tasks=true
		shift
		;;
	--safe)
		safe_mode=true
		shift
		;;
	--codex-mode)
		configure_codex_mode_paths
		shift
		;;
	--allow-external-git-dir)
		allow_external_git_dir=true
		shift
		;;
	--disable-git-worktree-common-dir)
		enable_git_worktree_common_dir=false
		shift
		;;
	--claude-command)
		if [[ $# -lt 2 ]]; then
			error "--claude-command requires an argument (command to use instead of 'claude')"
			exit 1
		fi
		claude_command_flag="$2"
		shift 2
		;;
	--command)
		if [[ $# -lt 2 ]]; then
			error "--command requires an argument (command to run instead of claude)"
			exit 1
		fi
		command_flag="$2"
		shift 2
		;;
	--env | -e)
		if [[ $# -lt 2 ]]; then
			error "--env requires an argument (KEY=VALUE or KEY)"
			exit 1
		fi
		custom_env_vars+=("$2")
		shift 2
		;;
	--packages | -p)
		if [[ $# -lt 2 ]]; then
			error "--packages requires an argument (package1,package2,...)"
			exit 1
		fi
		IFS=',' read -ra ADDR <<<"$2"
		for pkg in "${ADDR[@]}"; do
			custom_packages+=("$pkg")
		done
		shift 2
		;;
	--allow-readonly | --allow-readonly=*)
		if [[ "$1" == *"="* ]]; then
			path="${1#*=}"
			resolved=$(resolve_path "$path")
			add_ro_path "$resolved"
			shift
		else
			shift
			if [[ $# -eq 0 ]]; then
				error "--allow-readonly requires at least one path"
				exit 1
			fi
			while [[ $# -gt 0 ]] && [[ ! "$1" =~ ^- ]]; do
				resolved=$(resolve_path "$1")
				add_ro_path "$resolved"
				shift
			done
		fi
		;;
	--deny-path | --deny-path=*)
		if [[ "$1" == *"="* ]]; then
			path="${1#*=}"
			resolved=$(resolve_path "$path")
			add_deny_path "$resolved"
			shift
		else
			shift
			if [[ $# -eq 0 ]]; then
				error "--deny-path requires at least one path"
				exit 1
			fi
			while [[ $# -gt 0 ]] && [[ ! "$1" =~ ^- ]]; do
				resolved=$(resolve_path "$1")
				add_deny_path "$resolved"
				shift
			done
		fi
		;;
	--add-dir | --add-dir=*)
		# Handle --add-dir for both notations - this is a cco flag, not passed to command
		if [[ "$1" == *"="* ]]; then
			# --add-dir=<dir[:mode]> notation
			handle_add_dir_entry "${1#*=}"
			shift
		else
			# --add-dir <dir> notation
			shift
			# Collect directories until next flag or known subcommand
			while [[ $# -gt 0 ]] && [[ ! "$1" =~ ^- ]]; do
				# Stop if we hit a known subcommand
				case "$1" in
				shell | codex | droid | opencode | pi | gemini | self-update | cleanup | info | backup-creds | restore-creds | pull | rebuild)
					# This is a subcommand, not a directory
					break
					;;
				*)
					handle_add_dir_entry "$1"
					shift
					;;
				esac
			done
		fi
		;;
	--)
		# Everything after -- goes to the sandbox backend (docker/bwrap/sandbox-exec)
		shift
		sandbox_extra_args+=("$@")
		break
		;;
	*)
		# Not a cco flag, keep for subcommand/Claude processing
		remaining_args+=("$1")
		shift
		;;
	esac
done

persist_scope_root=$(resolve_persist_scope_root)
persist_scope_slug=$(persist_scope_slug_for_root "$persist_scope_root")
if using_custom_docker_image; then
	IMAGE_NAME="$docker_image_override"
fi

# Now handle subcommands with remaining args
set -- "${remaining_args[@]}"
CONTAINER_NAME=$(generate_container_name)
if [[ $# -gt 0 ]]; then
	case $1 in
	self-update)
		update_cco
		exit 0
		;;
	shell)
		shell_mode=true
		shift
		# All remaining arguments are shell command arguments
		claude_args=("$@")
		;;
	codex)
		# OpenAI Codex mode - set up the command and add default directory
		configure_agent_subcommand "codex"
		shift
		# All remaining arguments are passed to codex
		claude_args=("$@")
		;;
	droid)
		# Droid CLI mode - set up the command and add default directory
		configure_agent_subcommand "droid"
		shift
		# All remaining arguments are passed to droid
		claude_args=("$@")
		;;
	opencode)
		# OpenCode mode - set up the command and add default directory
		configure_agent_subcommand "opencode"
		shift
		# All remaining arguments are passed to opencode
		claude_args=("$@")
		;;
	pi)
		# Pi coding agent mode - YOLO by default, no skip-permissions flag needed
		configure_agent_subcommand "pi"
		shift
		# All remaining arguments are passed to pi
		claude_args=("$@")
		;;
	gemini)
		# Google Gemini CLI mode - use --yolo for autonomous operation
		configure_agent_subcommand "gemini"
		shift
		# All remaining arguments are passed to gemini
		claude_args=("$@")
		;;
	cleanup)
		log "Cleaning up cco containers..."
		containers=$(docker ps -a --format "{{.Names}}" | grep "^cco-" || true)
		if [[ -n "$containers" ]]; then
			echo "$containers" | xargs docker rm -f
			log "Cleanup complete"
		else
			log "No cco containers found"
		fi
		if [[ -d "$(persist_state_root)" ]]; then
			rm -rf "$(persist_state_root)"
			log "Removed persistent container state"
		fi
		exit 0
		;;
	info)
		show_info
		exit 0
		;;
	backup-creds)
		backup_credentials
		exit 0
		;;
	restore-creds)
		restore_credentials "$2"
		exit 0
		;;
	pull)
		if using_custom_docker_image; then
			log "Pulling Docker image: $IMAGE_NAME"
			check_dependencies
			docker pull "$IMAGE_NAME"
			log "Pull completed successfully"
			exit 0
		fi
		log "Pulling latest pre-built image..."
		check_dependencies
		if pull_prebuilt_image; then
			log "Pull completed successfully"
		else
			error "Failed to pull pre-built image"
			exit 1
		fi
		exit 0
		;;
	rebuild)
		if using_custom_docker_image; then
			error "rebuild cannot be used with --image or --docker-image"
			exit 1
		fi
		log "Rebuilding cco image..."
		check_dependencies
		build_image
		log "Rebuild completed successfully"
		exit 0
		;;
	--version | -v)
		show_version
		exit 0
		;;
	--help | -h)
		echo "cco - Claude Container (or Claude Condom if you're so inclined)"
		echo "A thin protective layer for Claude Code"
		echo ""
		echo "Usage: $0 [COMMAND|OPTIONS] [CLAUDE_ARGS...]"
		echo ""
		echo "Commands:"
		echo "  self-update         Update cco to latest version"
		echo "  shell [cmd...]      Run shell command in sandbox (or start an interactive shell)"
		echo "  codex [args...]     Run OpenAI Codex in sandbox"
		echo "  droid [args...]     Run Droid CLI in sandbox"
		echo "  opencode [args...]  Run OpenCode in sandbox"
		echo "  pi [args...]        Run Pi coding agent in sandbox"
		echo "  gemini [args...]    Run Google Gemini CLI in sandbox"
		echo "  cleanup             Remove all cco containers"
		echo "  info                Show system info and readiness"
		echo "  pull                Pull latest pre-built image"
		echo "  rebuild             Rebuild Docker image from source"
		echo "  backup-creds        Backup Claude Code credentials"
		echo "  restore-creds       Restore credentials from backup"
		echo ""
		echo "Options:"
		echo "  --rebuild             Force rebuild Docker image"
		echo "  --pull                Pull latest image before starting"
		echo "  --clean-old-images    Remove old cco image tags after a successful pull"
		echo "  --yes, -y             Auto-accept startup recovery prompts"
		echo "  --version, -v         Show version"
		echo "  --env, -e KEY=VAL     Set container environment variable"
		echo "  --packages, -p PKG    Install additional apt packages"
		echo "  --backend TYPE        Force sandbox backend (auto, native, docker)"
		echo "  --safe                Hide home dir except working dir (native only)"
		echo "  --codex-mode          Add Docker runtime flags for Codex compatibility"
		echo "  --allow-external-git-dir"
		echo "                        Trust and mount git common dirs outside normal layouts"
		echo "  --disable-git-worktree-common-dir"
		echo "                        Disable auto-detection/mounting of git worktree common dir"
		echo "  --docker-socket       Mount host Docker socket (experimental, defeats isolation)"
		echo "  --image IMAGE         Run Docker sessions from a specific image"
		echo "  --docker-image IMAGE  Alias for --image"
		echo "  --persist[=NAME]      Reuse a Docker container for this repo (Docker only)"
		echo "                        Also accepts: --persist NAME"
		echo "  --persist-container   Attach to an existing Docker container by name or ID"
		echo "  --force-docker-bridge-network"
		echo "                        Use bridge networking instead of host (Docker only)"
		echo "  --allow-oauth-refresh Allow OAuth token sync-back (experimental, creates backups)"
		echo "  --allow-keychain      Allow macOS Keychain access (DANGEROUS)"
		echo "  --enable-background-tasks"
		echo "                        Enable Claude Code background tasks"
		echo "  --claude-command CMD  Alternative Claude command (e.g., 'ccr code')"
		echo "  --command CMD         Run arbitrary command instead of Claude"
		echo "  --allow-readonly PATH Expose path read-only in sandbox"
		echo "                        Can be used inside --deny-path to create exceptions"
		echo "  --deny-path PATH      Hide path from sandbox"
		echo "                        Use --allow-readonly or --add-dir to allow specific subpaths"
		echo "  --add-dir PATH[:ro|rw]"
		echo "                        Allow tool access to directory (Claude Code option)"
		echo "  --help, -h            Show this help"
		echo ""
		echo "Sandbox Passthrough (-- args):"
		echo "  Arguments after -- are passed to the sandbox backend."
		echo "  Example: cco -- -p 3000:3000    # Forward port 3000 (Docker)"
		echo ""
		echo "Environment Variables:"
		echo "  CCO_CLAUDE_COMMAND    Alternative Claude command"
		echo "  CCO_COMMAND           Arbitrary command (overrides CCO_CLAUDE_COMMAND)"
		echo "  CCO_ALLOW_EXTERNAL_GIT_DIR=1"
		echo "                        Trust external git common dirs for worktree support"
		echo "  CCO_SANDBOX_ARGS_FILE Persistent sandbox args file (one arg per line)"
		echo "  ANTHROPIC_API_KEY     Passed through automatically"
		echo "  CLAUDE_CODE_OAUTH_TOKEN  Passed through (skips credential file check)"
		echo "  OPENAI_API_KEY        Passed through automatically"
		echo "  GEMINI_API_KEY        Passed through automatically"
		echo "  FACTORY_API_KEY       Passed through automatically"
		echo "  Also loads .env file and passes LLM provider keys, proxy settings, git config."
		echo ""
		echo "Requirements:"
		echo "  - macOS: sandbox-exec (built-in) or Docker"
		echo "  - Linux: bubblewrap (bwrap) or Docker"
		echo "  - Claude Code authenticated (run 'claude' to login)"
		echo ""
		echo "See README for detailed examples and sandbox args file format."
		exit 0
		;;
	*)
		# Not a subcommand, pass to Claude
		claude_args=("$@")
		;;
	esac
fi

# The main argument parsing loop has been moved to before subcommand handling
# to ensure cco flags like --add-dir are parsed first

# Main execution flow
main() {
	log "Starting cco..."

	# Detect sandbox backend
	detect_sandbox_backend "$SANDBOX_BACKEND"
	apply_agent_arg_policies

	if [[ ("$persist_mode" == true || -n "$persist_container_target") && "$SANDBOX_BACKEND" != "docker" ]]; then
		error "--persist and --persist-container are only supported with the Docker backend"
		exit 1
	fi

	if [[ -n "$docker_image_override" && "$SANDBOX_BACKEND" != "docker" ]]; then
		error "--image and --docker-image are only supported with the Docker backend"
		exit 1
	fi

	# Check dependencies based on backend
	check_dependencies
	if [[ "$SANDBOX_BACKEND" == "docker" ]]; then
		check_docker_dependencies
		if [[ "$safe_mode" == true ]]; then
			warn "--safe is only supported in native sandbox mode; ignoring for Docker backend"
			safe_mode=false
		fi
	fi

	# Only verify Claude authentication if we need it
	if needs_claude_authentication; then
		verify_claude_authentication
		ensure_refreshable_oauth_credentials
	fi

	# Only handle Docker image operations if using Docker backend
	if [[ "$SANDBOX_BACKEND" == "docker" ]]; then
		if using_custom_docker_image; then
			if [[ "$rebuild_image" = true ]]; then
				error "--rebuild cannot be used with --image or --docker-image"
				exit 1
			fi
			if [[ ${#custom_packages[@]} -gt 0 ]]; then
				error "--packages cannot be used with --image or --docker-image"
				exit 1
			fi
		fi

		# Handle --pull flag first
		if [[ "$pull_image" = true ]]; then
			if using_custom_docker_image; then
				log "Pulling Docker image: $IMAGE_NAME"
				docker pull "$IMAGE_NAME"
				log "Pull completed successfully"
			else
				log "Pulling latest pre-built image..."
				if pull_prebuilt_image; then
					log "Pull completed successfully"
				else
					warn "Failed to pull pre-built image, using existing or building locally"
				fi
			fi
		fi

		if using_custom_docker_image; then
			if docker image inspect "$IMAGE_NAME" &>/dev/null; then
				log "Using custom Docker image: $IMAGE_NAME"
			else
				log "Using custom Docker image: $IMAGE_NAME (Docker will pull it on first run if needed)"
			fi
		else
			# Determine whether to pull pre-built image or build locally
			if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
				# No local image exists
				if should_use_prebuilt_image; then
					# Try to pull pre-built image, fallback to build
					if ! pull_prebuilt_image; then
						build_image
					fi
				else
					# Build locally due to customizations
					if [[ "$rebuild_image" = true ]]; then
						log "Rebuilding cco image..."
					elif [[ ${#custom_packages[@]} -gt 0 ]]; then
						log "Custom packages specified, building image..."
					fi
					build_image
				fi
			elif [[ "$rebuild_image" = true ]] || [[ ${#custom_packages[@]} -gt 0 ]]; then
				# Force rebuild requested or customizations specified
				if [[ ${#custom_packages[@]} -gt 0 ]]; then
					log "Custom packages specified, building image..."
				else
					log "Rebuilding cco image..."
				fi
				docker image rm "$IMAGE_NAME" &>/dev/null || true
				build_image
			else
				log "Using existing cco image"
			fi
		fi
	fi

	# additionalDirectories from Claude project settings should only affect
	# actual Claude launches, not other frontends or arbitrary commands.
	if needs_claude_authentication; then
		load_additional_directories_from_settings
	fi

	# If inside a git worktree, the object store lives in the main repo's
	# .git directory, not the worktree. Add it as an additional dir so both
	# sandbox backends whitelist it for writes automatically.
	# Also check immediate subdirectories, since cco may be launched from a
	# parent folder that contains git worktree checkouts.
	if [[ "$enable_git_worktree_common_dir" == true ]] && command -v git &>/dev/null; then
		local _cco_check_dirs=("$PWD")
		# Scan immediate subdirs for git repos/worktrees via direct .git glob
		for _cco_gitdir in "$PWD"/*/.git; do
			[[ -e "$_cco_gitdir" ]] || continue
			_cco_check_dirs+=("${_cco_gitdir%/.git}")
		done

		for _cco_check_dir in "${_cco_check_dirs[@]}"; do
			local git_common_dir_raw git_dir_raw git_common_dir git_dir
			git_common_dir_raw="$(git -C "$_cco_check_dir" rev-parse --git-common-dir 2>/dev/null)" || true
			git_dir_raw="$(git -C "$_cco_check_dir" rev-parse --git-dir 2>/dev/null)" || true

			if [[ -n "$git_common_dir_raw" && -n "$git_dir_raw" ]]; then
				if git_common_dir="$(resolve_existing_dir "$git_common_dir_raw")"; then
					if git_dir="$(resolve_existing_dir "$git_dir_raw")"; then
						local trusted_layout=false
						if [[ "$git_dir" == "$git_common_dir" ]]; then
							trusted_layout=true
						elif [[ "$git_dir" == "$git_common_dir"/worktrees/* ]]; then
							trusted_layout=true
						fi

						if [[ "$trusted_layout" == true || "$allow_external_git_dir" == true ]]; then
							if [[ "$git_common_dir" != "$PWD"/.git ]] && ! path_in_array "$git_common_dir" "${additional_dirs[@]}"; then
								additional_dirs+=("$git_common_dir")
								git_worktree_common_dir="$git_common_dir"
								log "Adding git common dir for worktree support: $git_common_dir"
							fi
						else
							warn "Skipping untrusted git common dir layout: $git_common_dir"
							warn "Use --allow-external-git-dir (or CCO_ALLOW_EXTERNAL_GIT_DIR=1) to allow it"
						fi
					fi
				fi
			fi
		done
	elif [[ "$enable_git_worktree_common_dir" == false ]]; then
		log "Git worktree common-dir auto-detection disabled by flag"
	fi

	# Run with appropriate backend
	if [[ "$SANDBOX_BACKEND" == "native" ]]; then
		run_native_sandbox
	else
		run_container
	fi
}

main
